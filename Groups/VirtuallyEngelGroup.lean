import Groups.GeodesicGrowth

open Filter

namespace VirtuallyEngel

/-!
# A virtually Engel group

This file records Bodart's virtually `3`-step nilpotent example with intermediate geodesic
growth.
-/

/-- Generators in the two-generator presentation used for Bodart's virtually Engel group. -/
inductive Generator where
  | a
  | t
  deriving DecidableEq, Fintype

noncomputable instance : Primcodable Generator :=
  Primcodable.ofEquiv (Fin 2) (Fintype.equivFin Generator)

/-- The free-group word corresponding to the generator `a`. -/
abbrev A : FreeGroup Generator :=
  FreeGroup.of Generator.a

/-- The free-group word corresponding to the generator `t`. -/
abbrev T : FreeGroup Generator :=
  FreeGroup.of Generator.t

/-- The conjugate `t‚ĀĽ¬Ļ a t`, written `aŠĶó` in the literature. -/
abbrev Aconj : FreeGroup Generator :=
  T‚ĀĽ¬Ļ * A * T

/-- Hall's commutator convention is `x‚ĀĽ¬Ļ * y‚ĀĽ¬Ļ * x * y`, opposite to mathlib's
`‚ĀÖx, y‚ĀÜ = x * y * x‚ĀĽ¬Ļ * y‚ĀĽ¬Ļ`.

This is the middle generator matching the experimentally derived normal forms in the coordinate
model below. -/
abbrev HallX : FreeGroup Generator :=
  A‚ĀĽ¬Ļ * Aconj‚ĀĽ¬Ļ * A * Aconj

/-- The corresponding Hall-style third-step commutator. In coordinates this agrees with the
presentation commutator `C`. -/
abbrev HallY : FreeGroup Generator :=
  A‚ĀĽ¬Ļ * HallX‚ĀĽ¬Ļ * A * HallX

/-- The common third-step commutator in Bodart's presentation. -/
abbrev C : FreeGroup Generator :=
  ‚ĀÖA, ‚ĀÖA, Aconj‚ĀÜ‚ĀÜ

/-- Relators for Bodart's virtually Engel group:
`t¬≤ = 1`, `C = [aŠĶó, [a, aŠĶó]]`, and `C` commutes with both `a` and `aŠĶó`. -/
abbrev relators : Set (FreeGroup Generator) :=
  {T * T, C * (‚ĀÖAconj, ‚ĀÖA, Aconj‚ĀÜ‚ĀÜ)‚ĀĽ¬Ļ, ‚ĀÖC, A‚ĀÜ, ‚ĀÖC, Aconj‚ĀÜ}

/-- Bodart's virtually Engel group. -/
abbrev Group : Type :=
  PresentedGroup relators

/-- The geodesic-growth alphabet `S = {a, a‚ĀĽ¬Ļ, t}` used in Bodart's theorem. -/
inductive Letter where
  | a
  | aInv
  | t
  deriving DecidableEq, Fintype

/-- Interpretation of the Bodart alphabet in the presented group. -/
def letterValue : Letter ‚Üí Group
  | .a => PresentedGroup.mk relators A
  | .aInv => (PresentedGroup.mk relators A)‚ĀĽ¬Ļ
  | .t => PresentedGroup.mk relators T

/-- Geodesic growth with respect to `S = {a, a‚ĀĽ¬Ļ, t}`. -/
noncomputable abbrev geodesicGrowth : ‚Ąē ‚Üí ‚Ąē :=
  PresentedGroup.geodesicGrowth relators letterValue

/-- The comparison function appearing in Bodart's asymptotic estimate. -/
noncomputable def modelGrowth (n : ‚Ąē) : ‚ĄĚ :=
  Real.exp ((n : ‚ĄĚ).rpow ((3 : ‚ĄĚ) / 5) * Real.log (n : ‚ĄĚ))

/-- A literal formalization of `ő≥(n) ‚Čć exp(n^{3/5} log n)` as an eventual two-sided bound. -/
def theorem_4_statement : Prop :=
  ‚ąÉ c‚āĀ c‚āā : ‚ĄĚ,
    0 < c‚āĀ ‚ąß
    c‚āĀ ‚Č§ c‚āā ‚ąß
    ‚ąÄŠ∂† n : ‚Ąē in atTop,
      c‚āĀ * modelGrowth n ‚Č§ (geodesicGrowth n : ‚ĄĚ) ‚ąß
      (geodesicGrowth n : ‚ĄĚ) ‚Č§ c‚āā * modelGrowth n

/-!
## A computable coordinate model

The next step toward an internal proof of the Bodart witness facts is to work with an explicit
computable model of the underlying virtually Engel group. The model below packages the Engel
subgroup by integer coordinates coming from Bodart's path invariants, together with an order-two
symmetry acting by reflection.
-/

/-- Integer coordinates for the Engel subgroup generated by the two diagonal steps
`a = (1, 0, 0, 0)` and `b = (0, 1, 0, 0)`.

The fields are the two diagonal coordinates together with the algebraic area and three times the
`y`-barycenter used in Bodart's path model. -/
structure EngelCoords where
  u : ‚Ą§
  v : ‚Ą§
  area : ‚Ą§
  bary3 : ‚Ą§
  deriving DecidableEq

noncomputable instance : Primcodable EngelCoords :=
  Primcodable.ofEquiv (‚Ą§ √ó ‚Ą§ √ó ‚Ą§ √ó ‚Ą§)
    { toFun := fun g => (g.u, g.v, g.area, g.bary3)
      invFun := fun p => ‚ü®p.1, p.2.1, p.2.2.1, p.2.2.2‚ü©
      left_inv := by
        intro g
        cases g
        rfl
      right_inv := by
        intro p
        cases p
        rfl }

/-- Half of the determinant term appearing in Bodart's concatenation formula, expressed in the
diagonal coordinates. -/
def EngelCoords.det2 (g h : EngelCoords) : ‚Ą§ :=
  g.v * h.u - g.u * h.v

instance : Mul EngelCoords where
  mul g h :=
    { u := g.u + h.u
      v := g.v + h.v
      area := g.area + h.area + EngelCoords.det2 g h
      bary3 := g.bary3 + h.bary3 + 3 * (g.u - g.v) * h.area +
        (2 * (g.u - g.v) + (h.u - h.v)) * EngelCoords.det2 g h }

instance : One EngelCoords where
  one := ‚ü®0, 0, 0, 0‚ü©

instance : Inv EngelCoords where
  inv g := ‚ü®-g.u, -g.v, -g.area, -g.bary3 + 3 * (g.u - g.v) * g.area‚ü©

@[simp] theorem EngelCoords.mul_u (g h : EngelCoords) : (g * h).u = g.u + h.u := rfl
@[simp] theorem EngelCoords.mul_v (g h : EngelCoords) : (g * h).v = g.v + h.v := rfl
@[simp] theorem EngelCoords.mul_area (g h : EngelCoords) :
    (g * h).area = g.area + h.area + EngelCoords.det2 g h := rfl
@[simp] theorem EngelCoords.mul_bary3 (g h : EngelCoords) :
    (g * h).bary3 = g.bary3 + h.bary3 + 3 * (g.u - g.v) * h.area +
      (2 * (g.u - g.v) + (h.u - h.v)) * EngelCoords.det2 g h := rfl
@[simp] theorem EngelCoords.one_u : (1 : EngelCoords).u = 0 := rfl
@[simp] theorem EngelCoords.one_v : (1 : EngelCoords).v = 0 := rfl
@[simp] theorem EngelCoords.one_area : (1 : EngelCoords).area = 0 := rfl
@[simp] theorem EngelCoords.one_bary3 : (1 : EngelCoords).bary3 = 0 := rfl
@[simp] theorem EngelCoords.inv_u (g : EngelCoords) : g‚ĀĽ¬Ļ.u = -g.u := rfl
@[simp] theorem EngelCoords.inv_v (g : EngelCoords) : g‚ĀĽ¬Ļ.v = -g.v := rfl
@[simp] theorem EngelCoords.inv_area (g : EngelCoords) : g‚ĀĽ¬Ļ.area = -g.area := rfl
@[simp] theorem EngelCoords.inv_bary3 (g : EngelCoords) :
    g‚ĀĽ¬Ļ.bary3 = -g.bary3 + 3 * (g.u - g.v) * g.area := rfl

@[ext]
theorem EngelCoords.ext
    {g h : EngelCoords}
    (hu : g.u = h.u) (hv : g.v = h.v) (harea : g.area = h.area)
    (hbary3 : g.bary3 = h.bary3) : g = h := by
  cases g
  cases h
  simp_all

instance : _root_.Group EngelCoords where
  mul_assoc g h k := by
    ext <;> simp [EngelCoords.det2] <;> ring
  one_mul g := by
    ext <;> simp [EngelCoords.det2]
  mul_one g := by
    ext <;> simp [EngelCoords.det2]
  inv_mul_cancel g := by
    ext <;> simp [EngelCoords.det2] <;> ring

/-- The coordinate image of the diagonal step `a`. -/
abbrev engelA : EngelCoords :=
  ‚ü®1, 0, 0, 0‚ü©

/-- The coordinate image of `aŠĶó = t‚ĀĽ¬Ļ a t`. -/
abbrev engelAconj : EngelCoords :=
  ‚ü®0, -1, 0, 0‚ü©

/-- The corrected Hall-style commutator generator. -/
abbrev engelHallX : EngelCoords :=
  ‚ü®0, 0, 2, -6‚ü©

/-- The central Hall-style commutator generator. -/
abbrev engelHallY : EngelCoords :=
  ‚ü®0, 0, 0, 6‚ü©

@[simp] theorem engelA_pow (n : ‚Ąē) : engelA ^ n = ‚ü®n, 0, 0, 0‚ü© := by
  induction n with
  | zero => rfl
  | succ n ih =>
      ext <;> simp [engelA, pow_succ, ih, EngelCoords.det2] <;> ring

@[simp] theorem engelAconj_pow (n : ‚Ąē) : engelAconj ^ n = ‚ü®0, -(n : ‚Ą§), 0, 0‚ü© := by
  induction n with
  | zero => rfl
  | succ n ih =>
      ext <;> simp [engelAconj, pow_succ, ih, EngelCoords.det2] <;> ring

@[simp] theorem engelHallX_pow (n : ‚Ąē) :
    engelHallX ^ n = ‚ü®0, 0, 2 * (n : ‚Ą§), -6 * (n : ‚Ą§)‚ü© := by
  induction n with
  | zero => rfl
  | succ n ih =>
      ext <;> simp [engelHallX, pow_succ, ih, EngelCoords.det2] <;> ring

@[simp] theorem engelHallY_pow (n : ‚Ąē) :
    engelHallY ^ n = ‚ü®0, 0, 0, 6 * (n : ‚Ą§)‚ü© := by
  induction n with
  | zero => rfl
  | succ n ih =>
      ext <;> simp [engelHallY, pow_succ, ih, EngelCoords.det2] <;> ring

@[simp] theorem engelA_zpow (n : ‚Ą§) : engelA ^ n = ‚ü®n, 0, 0, 0‚ü© := by
  cases n with
  | ofNat n =>
      simpa [zpow_natCast] using engelA_pow n
  | negSucc n =>
      change engelA ^ Int.negSucc n = ‚ü®Int.negSucc n, 0, 0, 0‚ü©
      rw [zpow_negSucc, engelA_pow]
      ext <;> simp [Int.negSucc_eq]

@[simp] theorem engelAconj_zpow (n : ‚Ą§) : engelAconj ^ n = ‚ü®0, -n, 0, 0‚ü© := by
  cases n with
  | ofNat n =>
      simpa [zpow_natCast] using engelAconj_pow n
  | negSucc n =>
      change engelAconj ^ Int.negSucc n = ‚ü®0, -(Int.negSucc n), 0, 0‚ü©
      rw [zpow_negSucc, engelAconj_pow]
      ext <;> simp [Int.negSucc_eq]

@[simp] theorem engelHallX_zpow (n : ‚Ą§) :
    engelHallX ^ n = ‚ü®0, 0, 2 * n, -6 * n‚ü© := by
  cases n with
  | ofNat n =>
      simpa [zpow_natCast] using engelHallX_pow n
  | negSucc n =>
      change engelHallX ^ Int.negSucc n = ‚ü®0, 0, 2 * Int.negSucc n, -6 * Int.negSucc n‚ü©
      rw [zpow_negSucc, engelHallX_pow]
      ext <;> simp [Int.negSucc_eq] <;> ring

@[simp] theorem engelHallY_zpow (n : ‚Ą§) :
    engelHallY ^ n = ‚ü®0, 0, 0, 6 * n‚ü© := by
  cases n with
  | ofNat n =>
      simpa [zpow_natCast] using engelHallY_pow n
  | negSucc n =>
      change engelHallY ^ Int.negSucc n = ‚ü®0, 0, 0, 6 * Int.negSucc n‚ü©
      rw [zpow_negSucc, engelHallY_pow]
      ext <;> simp [Int.negSucc_eq] <;> ring

/-- The order-two symmetry induced by reflection across the `y`-axis in Bodart's path model. -/
def EngelCoords.reflect (g : EngelCoords) : EngelCoords :=
  ‚ü®-g.v, -g.u, -g.area, -g.bary3‚ü©

@[simp] theorem EngelCoords.reflect_reflect (g : EngelCoords) :
    g.reflect.reflect = g := by
  ext <;> simp [EngelCoords.reflect]

@[simp] theorem EngelCoords.reflect_mul (g h : EngelCoords) :
    (g * h).reflect = g.reflect * h.reflect := by
  ext <;> simp [EngelCoords.reflect, EngelCoords.det2] <;> ring

/-- Reflection as a multiplicative automorphism of the Engel-coordinate group. -/
def EngelCoords.reflectAut : MulAut EngelCoords where
  toFun := EngelCoords.reflect
  invFun := EngelCoords.reflect
  left_inv := EngelCoords.reflect_reflect
  right_inv := EngelCoords.reflect_reflect
  map_mul' := EngelCoords.reflect_mul

/-- The order-two symmetry adjoining the Engel subgroup. -/
inductive Symmetry where
  | id
  | flip
  deriving DecidableEq, Fintype

instance : One Symmetry where
  one := .id

instance : Mul Symmetry where
  mul
    | .id, x => x
    | .flip, .id => .flip
    | .flip, .flip => .id

instance : Inv Symmetry where
  inv := id

@[simp] theorem Symmetry.inv_id : (Symmetry.id)‚ĀĽ¬Ļ = Symmetry.id := rfl
@[simp] theorem Symmetry.inv_flip : (Symmetry.flip)‚ĀĽ¬Ļ = Symmetry.flip := rfl

instance : _root_.Group Symmetry where
  mul_assoc a b c := by
    cases a <;> cases b <;> cases c <;> rfl
  one_mul a := by
    cases a <;> rfl
  mul_one a := by
    cases a <;> rfl
  inv_mul_cancel a := by
    cases a <;> rfl

noncomputable instance : Primcodable Symmetry :=
  Primcodable.ofEquiv (Fin 2) (Fintype.equivFin Symmetry)

/-- The reflection action of the order-two symmetry on Engel coordinates. -/
def symmetryAction : Symmetry ‚Üí* MulAut EngelCoords where
  toFun
    | .id => 1
    | .flip => EngelCoords.reflectAut
  map_one' := rfl
  map_mul' := by
    intro a b
    cases a <;> cases b
    ¬∑ rfl
    ¬∑ rfl
    ¬∑ rfl
    ¬∑ exact DFunLike.ext _ _ fun g => by
        simp [MulAut.mul_apply, EngelCoords.reflectAut, EngelCoords.reflect]

/-- A computable semidirect-product model for Bodart's virtually Engel group. -/
abbrev CoordGroup :=
  EngelCoords ‚čä[symmetryAction] Symmetry

/-- The diagonal generator `a` inside the coordinate model. -/
abbrev coordA : CoordGroup :=
  SemidirectProduct.inl engelA

/-- The diagonal generator `b` inside the Engel subgroup. -/
abbrev coordB : CoordGroup :=
  SemidirectProduct.inl ‚ü®0, 1, 0, 0‚ü©

/-- The coordinate image of `aŠĶó`. -/
abbrev coordAconj : CoordGroup :=
  SemidirectProduct.inl engelAconj

/-- The corrected Hall-style middle commutator. -/
abbrev coordHallX : CoordGroup :=
  SemidirectProduct.inl engelHallX

/-- The central Hall-style commutator. -/
abbrev coordHallY : CoordGroup :=
  SemidirectProduct.inl engelHallY

/-- The order-two symmetry `t` inside the coordinate model. -/
abbrev coordT : CoordGroup :=
  SemidirectProduct.inr Symmetry.flip

/-- The presentation generators interpreted in the computable coordinate model. -/
def coordGenerator : Generator ‚Üí CoordGroup
  | .a => coordA
  | .t => coordT

@[simp] theorem coordA_zpow (n : ‚Ą§) : coordA ^ n = SemidirectProduct.inl ‚ü®n, 0, 0, 0‚ü© := by
  simpa [coordA] using
    (((SemidirectProduct.inl : EngelCoords ‚Üí* CoordGroup).map_zpow engelA n).symm)

@[simp] theorem coordAconj_zpow (n : ‚Ą§) :
    coordAconj ^ n = SemidirectProduct.inl ‚ü®0, -n, 0, 0‚ü© := by
  simpa [coordAconj] using
    (((SemidirectProduct.inl : EngelCoords ‚Üí* CoordGroup).map_zpow engelAconj n).symm)

@[simp] theorem coordHallX_zpow (n : ‚Ą§) :
    coordHallX ^ n = SemidirectProduct.inl ‚ü®0, 0, 2 * n, -6 * n‚ü© := by
  simpa [coordHallX] using
    (((SemidirectProduct.inl : EngelCoords ‚Üí* CoordGroup).map_zpow engelHallX n).symm)

@[simp] theorem coordHallY_zpow (n : ‚Ą§) :
    coordHallY ^ n = SemidirectProduct.inl ‚ü®0, 0, 0, 6 * n‚ü© := by
  simpa [coordHallY] using
    (((SemidirectProduct.inl : EngelCoords ‚Üí* CoordGroup).map_zpow engelHallY n).symm)

@[simp] theorem coordT_sq : coordT * coordT = 1 := by
  native_decide

@[simp] theorem coord_conj_a :
    coordT‚ĀĽ¬Ļ * coordA * coordT = coordB‚ĀĽ¬Ļ := by
  native_decide

@[simp] theorem coord_aconj :
    FreeGroup.lift coordGenerator Aconj = coordAconj := by
  native_decide

/-- This records the commutator-convention mismatch: mathlib's `‚ĀÖA, Aconj‚ĀÜ` is not the Hall
generator used by the experimentally derived normal forms. -/
@[simp] theorem coord_mathlib_commutator :
    FreeGroup.lift coordGenerator ‚ĀÖA, Aconj‚ĀÜ = SemidirectProduct.inl ‚ü®0, 0, 2, 6‚ü© := by
  native_decide

@[simp] theorem coord_hallX :
    FreeGroup.lift coordGenerator HallX = coordHallX := by
  native_decide

@[simp] theorem coord_hallY :
    FreeGroup.lift coordGenerator HallY = coordHallY := by
  native_decide

@[simp] theorem coord_C :
    FreeGroup.lift coordGenerator C = coordHallY := by
  native_decide

@[simp] theorem coord_relator_t2 :
    FreeGroup.lift coordGenerator (T * T) = 1 := by
  native_decide

@[simp] theorem coord_relator_commutator :
    FreeGroup.lift coordGenerator (C * (‚ĀÖAconj, ‚ĀÖA, Aconj‚ĀÜ‚ĀÜ)‚ĀĽ¬Ļ) = 1 := by
  native_decide

@[simp] theorem coord_relator_central_a :
    FreeGroup.lift coordGenerator ‚ĀÖC, A‚ĀÜ = 1 := by
  native_decide

@[simp] theorem coord_relator_central_aconj :
    FreeGroup.lift coordGenerator ‚ĀÖC, Aconj‚ĀÜ = 1 := by
  native_decide

/-- The presentation maps into the computable coordinate model. This is the concrete target for
the eventual internal proof of the word-problem witness. -/
def toCoordGroup : PresentedGroup relators ‚Üí* CoordGroup :=
  PresentedGroup.toGroup (f := coordGenerator) <| by
    intro r hr
    simp only [relators, Set.mem_insert_iff, Set.mem_singleton_iff] at hr
    rcases hr with rfl | rfl | rfl | rfl
    ¬∑ exact coord_relator_t2
    ¬∑ exact coord_relator_commutator
    ¬∑ exact coord_relator_central_a
    ¬∑ exact coord_relator_central_aconj

/-!
## The lattice cut out by the generators

The explicit coordinate model above is larger than the subgroup generated by the two diagonal
steps. The latter is cut out by two congruence conditions, corresponding to the area and
barycentric coordinates in Bodart's path model.
-/

/-- The parity residue governing the area coordinate of the Engel lattice. -/
def EngelCoords.areaResidue (g : EngelCoords) : ‚Ą§ :=
  g.area + g.u * g.v

/-- The congruence residue governing the barycentric coordinate of the Engel lattice. -/
def EngelCoords.baryResidue (g : EngelCoords) : ‚Ą§ :=
  g.bary3 - 3 * g.area * (g.u - g.v) - g.u * g.u * g.v + 2 * g.u * g.v * g.v

/-- The lattice subgroup generated by the two diagonal steps inside the coordinate model. -/
def EngelCoords.InLattice (g : EngelCoords) : Prop :=
  2 ‚ą£ g.areaResidue ‚ąß 6 ‚ą£ g.baryResidue

@[simp] theorem EngelCoords.areaResidue_one : (1 : EngelCoords).areaResidue = 0 := by
  simp [EngelCoords.areaResidue]

@[simp] theorem EngelCoords.baryResidue_one : (1 : EngelCoords).baryResidue = 0 := by
  simp [EngelCoords.baryResidue]

@[simp] theorem EngelCoords.areaResidue_mul (g h : EngelCoords) :
    (g * h).areaResidue = g.areaResidue + h.areaResidue + 2 * g.v * h.u := by
  simp [EngelCoords.areaResidue, EngelCoords.det2]
  ring

@[simp] theorem EngelCoords.baryResidue_mul (g h : EngelCoords) :
    (g * h).baryResidue =
      g.baryResidue + h.baryResidue
        - 3 * ((g.areaResidue) * (h.u - h.v) + h.u * g.v * (h.u - g.v - 2 * h.v)) := by
  simp [EngelCoords.baryResidue, EngelCoords.areaResidue, EngelCoords.det2]
  ring

@[simp] theorem EngelCoords.areaResidue_inv (g : EngelCoords) :
    g‚ĀĽ¬Ļ.areaResidue = -g.areaResidue + 2 * g.u * g.v := by
  simp [EngelCoords.areaResidue]
  ring

@[simp] theorem EngelCoords.baryResidue_inv (g : EngelCoords) :
    g‚ĀĽ¬Ļ.baryResidue = -g.baryResidue - 3 * g.area * (g.u - g.v) := by
  simp [EngelCoords.baryResidue]
  ring

@[simp] theorem EngelCoords.areaResidue_reflect (g : EngelCoords) :
    g.reflect.areaResidue = -g.areaResidue + 2 * g.u * g.v := by
  simp [EngelCoords.reflect, EngelCoords.areaResidue]
  ring

@[simp] theorem EngelCoords.baryResidue_reflect (g : EngelCoords) :
    g.reflect.baryResidue = -g.baryResidue - 3 * g.u * g.v * (g.u - g.v) := by
  simp [EngelCoords.reflect, EngelCoords.baryResidue]
  ring

@[simp] theorem EngelCoords.inLattice_one : EngelCoords.InLattice 1 := by
  simp [EngelCoords.InLattice]

theorem EngelCoords.inLattice_mul {g h : EngelCoords}
    (hg : EngelCoords.InLattice g) (hh : EngelCoords.InLattice h) :
    EngelCoords.InLattice (g * h) := by
  rcases hg with ‚ü®hgArea, hgBary‚ü©
  rcases hh with ‚ü®hhArea, hhBary‚ü©
  constructor
  ¬∑ rcases hgArea with ‚ü®kg, hkg‚ü©
    rcases hhArea with ‚ü®kh, hkh‚ü©
    have hmul := EngelCoords.areaResidue_mul g h
    refine ‚ü®kg + kh + g.v * h.u, ?_‚ü©
    rw [hmul, hkg, hkh]
    ring
  ¬∑ rcases hgBary with ‚ü®lg, hlg‚ü©
    rcases hhBary with ‚ü®lh, hlh‚ü©
    have hEvenCorr : 2 ‚ą£ g.areaResidue * (h.u - h.v) + h.u * g.v * (h.u - g.v - 2 * h.v) := by
      have h‚āĀ : 2 ‚ą£ g.areaResidue * (h.u - h.v) := by
        rcases hgArea with ‚ü®kg, hkg‚ü©
        refine ‚ü®kg * (h.u - h.v), ?_‚ü©
        rw [hkg]
        ring
      have h‚āāeven : Even (h.u * g.v * (h.u - g.v - 2 * h.v)) := by
        by_cases hu : Even h.u
        ¬∑ exact Int.even_mul.mpr <| Or.inl <| Int.even_mul.mpr <| Or.inl hu
        ¬∑ by_cases hv : Even g.v
          ¬∑ exact Int.even_mul.mpr <| Or.inl <| Int.even_mul.mpr <| Or.inr hv
          ¬∑ have hsub : Even (h.u - g.v) := by
              rw [Int.even_sub]
              simp [hu, hv]
            have htwov : Even (2 * h.v) := by
              exact Int.even_mul.mpr <| Or.inl (by decide : Even (2 : ‚Ą§))
            have hparen : Even (h.u - g.v - 2 * h.v) := by
              rw [Int.even_sub]
              simp [hsub, htwov]
            exact Int.even_mul.mpr <| Or.inr hparen
      exact dvd_add h‚āĀ (even_iff_two_dvd.mp h‚āāeven)
    rcases hEvenCorr with ‚ü®kc, hkc‚ü©
    have hmul := EngelCoords.baryResidue_mul g h
    refine ‚ü®lg + lh - kc, ?_‚ü©
    rw [hmul, hlg, hlh, hkc]
    ring

theorem EngelCoords.inLattice_inv {g : EngelCoords} (hg : EngelCoords.InLattice g) :
    EngelCoords.InLattice g‚ĀĽ¬Ļ := by
  rcases hg with ‚ü®hgArea, hgBary‚ü©
  constructor
  ¬∑ rcases hgArea with ‚ü®kg, hkg‚ü©
    have hinv := EngelCoords.areaResidue_inv g
    refine ‚ü®-kg + g.u * g.v, ?_‚ü©
    rw [hinv, hkg]
    ring
  ¬∑ rcases hgBary with ‚ü®lg, hlg‚ü©
    have hEven : 2 ‚ą£ g.area * (g.u - g.v) := by
      rcases hgArea with ‚ü®kg, hkg‚ü©
      have hsum : 2 ‚ą£ (g.area + g.u * g.v) * (g.u - g.v) := by
        have hkg' : g.area + g.u * g.v = 2 * kg := by
          simpa [EngelCoords.areaResidue] using hkg
        refine ‚ü®kg * (g.u - g.v), ?_‚ü©
        rw [hkg']
        ring
      have huvEven : Even (g.u * g.v * (g.u - g.v)) := by
        by_cases hu : Even g.u
        ¬∑ exact Int.even_mul.mpr <| Or.inl <| Int.even_mul.mpr <| Or.inl hu
        ¬∑ by_cases hv : Even g.v
          ¬∑ exact Int.even_mul.mpr <| Or.inl <| Int.even_mul.mpr <| Or.inr hv
          ¬∑ have hsub : Even (g.u - g.v) := by
              rw [Int.even_sub]
              simp [hu, hv]
            exact Int.even_mul.mpr <| Or.inr hsub
      have huv : 2 ‚ą£ g.u * g.v * (g.u - g.v) := even_iff_two_dvd.mp huvEven
      have hrepr :
          g.area * (g.u - g.v) =
            (g.area + g.u * g.v) * (g.u - g.v) - g.u * g.v * (g.u - g.v) := by
        ring
      rw [hrepr]
      exact dvd_sub hsum huv
    rcases hEven with ‚ü®kc, hkc‚ü©
    have hinv := EngelCoords.baryResidue_inv g
    refine ‚ü®-lg - kc, ?_‚ü©
    nlinarith [hinv, hlg, hkc]

theorem EngelCoords.inLattice_reflect {g : EngelCoords} (hg : EngelCoords.InLattice g) :
    EngelCoords.InLattice g.reflect := by
  rcases hg with ‚ü®hgArea, hgBary‚ü©
  constructor
  ¬∑ rcases hgArea with ‚ü®kg, hkg‚ü©
    have hreflect := EngelCoords.areaResidue_reflect g
    refine ‚ü®-kg + g.u * g.v, ?_‚ü©
    rw [hreflect, hkg]
    ring
  ¬∑ rcases hgBary with ‚ü®lg, hlg‚ü©
    have hEven : 2 ‚ą£ g.u * g.v * (g.u - g.v) := by
      have hEvenProd : Even (g.u * g.v * (g.u - g.v)) := by
        by_cases hu : Even g.u
        ¬∑ exact Int.even_mul.mpr <| Or.inl <| Int.even_mul.mpr <| Or.inl hu
        ¬∑ by_cases hv : Even g.v
          ¬∑ exact Int.even_mul.mpr <| Or.inl <| Int.even_mul.mpr <| Or.inr hv
          ¬∑ have hsub : Even (g.u - g.v) := by
              rw [Int.even_sub]
              simp [hu, hv]
            exact Int.even_mul.mpr <| Or.inr hsub
      exact even_iff_two_dvd.mp hEvenProd
    rcases hEven with ‚ü®kc, hkc‚ü©
    have hreflect := EngelCoords.baryResidue_reflect g
    refine ‚ü®-lg - kc, ?_‚ü©
    nlinarith [hreflect, hlg, hkc]

theorem EngelCoords.inLattice_action {g : EngelCoords} (s : Symmetry)
    (hg : EngelCoords.InLattice g) :
    EngelCoords.InLattice (symmetryAction s g) := by
  cases s
  ¬∑ simpa [symmetryAction] using hg
  ¬∑ simpa [symmetryAction, EngelCoords.reflectAut] using EngelCoords.inLattice_reflect hg

/-- The actual coordinate subgroup in which the presented group lands. -/
def coordLattice : Subgroup CoordGroup where
  carrier := {g | EngelCoords.InLattice g.left}
  one_mem' := EngelCoords.inLattice_one
  mul_mem' {g h} hg hh := by
    have hh' : EngelCoords.InLattice (symmetryAction g.right h.left) :=
      EngelCoords.inLattice_action g.right hh
    simpa [SemidirectProduct.mul_left] using EngelCoords.inLattice_mul hg hh'
  inv_mem' {g} hg := by
    have hInv : EngelCoords.InLattice g.left‚ĀĽ¬Ļ := EngelCoords.inLattice_inv hg
    have hAct : EngelCoords.InLattice (symmetryAction g.right‚ĀĽ¬Ļ g.left‚ĀĽ¬Ļ) :=
      EngelCoords.inLattice_action g.right‚ĀĽ¬Ļ hInv
    simpa [SemidirectProduct.inv_left] using hAct

@[simp] theorem coordA_mem_lattice : coordA ‚ąą coordLattice := by
  show EngelCoords.InLattice ({ u := 1, v := 0, area := 0, bary3 := 0 } : EngelCoords)
  simp [EngelCoords.InLattice, EngelCoords.areaResidue, EngelCoords.baryResidue]

@[simp] theorem coordT_mem_lattice : coordT ‚ąą coordLattice := by
  show EngelCoords.InLattice (1 : EngelCoords)
  simp [EngelCoords.InLattice, EngelCoords.areaResidue, EngelCoords.baryResidue]

/-- The presentation generators interpreted in the lattice subgroup of the coordinate model. -/
def coordLatticeGenerator : Generator ‚Üí coordLattice
  | .a => ‚ü®coordA, coordA_mem_lattice‚ü©
  | .t => ‚ü®coordT, coordT_mem_lattice‚ü©

/-!
## Corrected Hall-style normal forms

With mathlib's commutator convention, the literal word `‚ĀÖA, Aconj‚ĀÜ` lands at coordinate
`(0, 0, 2, 6)`. The experimentally derived normal forms instead use the Hall-style commutator
`HallX = A‚ĀĽ¬Ļ * Aconj‚ĀĽ¬Ļ * A * Aconj`, whose coordinate is `(0, 0, 2, -6)`. The theorems below
package the resulting normal-form formulas and provide a computable spelling of every element in
the coordinate lattice.
-/

/-- Hall-style normal-form word on the Engel subgroup. The exponent on `Aconj` is the literal
free-group exponent, so the second lattice coordinate is `-v`. -/
def hallNormalWord (u v m n : ‚Ą§) : FreeGroup Generator :=
  A ^ u * Aconj ^ v * HallX ^ m * HallY ^ n

theorem coord_hallNormalWord (u v m n : ‚Ą§) :
    FreeGroup.lift coordGenerator (hallNormalWord u v m n) =
      SemidirectProduct.inl
        ‚ü®u, -v, u * v + 2 * m,
          u * v * (2 * u + v) + 6 * m * (u + v - 1) + 6 * n‚ü© := by
  refine SemidirectProduct.ext ?_ ?_
  ¬∑ apply EngelCoords.ext <;> simp [hallNormalWord, coordGenerator, EngelCoords.det2] <;> ring
  ¬∑ simp [hallNormalWord, coordGenerator]

/-- In the corrected Hall normal form, the two lattice congruence invariants are exactly the
exponents of the Hall commutators, up to the simple linear shift `n ‚Ü¶ n - m`. -/
theorem hallNormalWord_areaResidue (u v m n : ‚Ą§) :
    (FreeGroup.lift coordGenerator (hallNormalWord u v m n)).left.areaResidue = 2 * m := by
  simpa [coord_hallNormalWord, EngelCoords.areaResidue]

theorem hallNormalWord_baryResidue (u v m n : ‚Ą§) :
    (FreeGroup.lift coordGenerator (hallNormalWord u v m n)).left.baryResidue = 6 * (n - m) := by
  simp [coord_hallNormalWord, EngelCoords.baryResidue]
  ring

/-- The Hall exponent recovered from the area congruence. -/
def EngelCoords.hallM (g : EngelCoords) : ‚Ą§ :=
  g.areaResidue / 2

/-- The Hall exponent recovered from the barycentric congruence. -/
def EngelCoords.hallN (g : EngelCoords) : ‚Ą§ :=
  g.hallM + g.baryResidue / 6

/-- The corrected Hall normal-form word attached to a lattice point. -/
def EngelCoords.hallWord (g : EngelCoords) : FreeGroup Generator :=
  hallNormalWord g.u (-g.v) g.hallM g.hallN

theorem EngelCoords.area_eq_hallM {g : EngelCoords} (hg : EngelCoords.InLattice g) :
    g.area = -g.u * g.v + 2 * g.hallM := by
  have hdiv : g.areaResidue / 2 * 2 = g.areaResidue := Int.ediv_mul_cancel hg.1
  calc
    g.area = g.areaResidue - g.u * g.v := by simpa [EngelCoords.areaResidue]
    _ = g.areaResidue / 2 * 2 - g.u * g.v := by rw [hdiv]
    _ = -g.u * g.v + 2 * g.hallM := by
      simp [EngelCoords.hallM]
      ring

theorem EngelCoords.bary3_eq_hallM_hallN {g : EngelCoords} (hg : EngelCoords.InLattice g) :
    g.bary3 =
      -g.u * g.v * (2 * g.u - g.v) + 6 * g.hallM * (g.u - g.v - 1) + 6 * g.hallN := by
  have hdiv : g.baryResidue / 6 * 6 = g.baryResidue := Int.ediv_mul_cancel hg.2
  rw [EngelCoords.hallN]
  calc
    g.bary3 =
      g.baryResidue + 3 * g.area * (g.u - g.v) + g.u * g.u * g.v - 2 * g.u * g.v * g.v := by
        simp [EngelCoords.baryResidue]
        ring
    _ =
      g.baryResidue / 6 * 6 + 3 * (-g.u * g.v + 2 * g.hallM) * (g.u - g.v) +
        g.u * g.u * g.v - 2 * g.u * g.v * g.v := by
          rw [hdiv, EngelCoords.area_eq_hallM hg]
    _ =
      -g.u * g.v * (2 * g.u - g.v) + 6 * g.hallM * (g.u - g.v - 1) +
        6 * (g.hallM + g.baryResidue / 6) := by
          ring

theorem EngelCoords.hallWord_spec {g : EngelCoords} (hg : EngelCoords.InLattice g) :
    FreeGroup.lift coordGenerator g.hallWord = SemidirectProduct.inl g := by
  rw [EngelCoords.hallWord, coord_hallNormalWord]
  refine SemidirectProduct.ext ?_ ?_
  ¬∑ apply EngelCoords.ext <;>
      simp [EngelCoords.area_eq_hallM hg, EngelCoords.bary3_eq_hallM_hallN hg] <;> ring
  ¬∑ rfl

/-- A word spelling the order-two symmetry. -/
def symmetryWord : Symmetry ‚Üí FreeGroup Generator
  | .id => 1
  | .flip => T

@[simp] theorem coord_symmetryWord (s : Symmetry) :
    FreeGroup.lift coordGenerator (symmetryWord s) = SemidirectProduct.inr s := by
  cases s <;> rfl

/-- A computable spelling of an element of the coordinate lattice by the corrected Hall normal
form together with the final symmetry letter. -/
def coordLatticeWord (g : coordLattice) : FreeGroup Generator :=
  g.1.left.hallWord * symmetryWord g.1.right

theorem coordLatticeWord_spec (g : coordLattice) :
    FreeGroup.lift coordGenerator (coordLatticeWord g) = g.1 := by
  rw [coordLatticeWord, map_mul, EngelCoords.hallWord_spec g.2, coord_symmetryWord]
  simpa using (SemidirectProduct.mk_eq_inl_mul_inr g.1.right g.1.left).symm

/-!
## Hall commutation identities inside `PresentedGroup relators`

These identities are the algebraic input to the multiplication-compatibility identity that
discharges `toCoordGroup_injective`. They are stated at the level of `PresentedGroup relators` and
established either by pure free-group algebra (definition of `HallX`, `HallY`, `Aconj`) or by
using one of the four defining relators.
-/

/-- `mk (T * T) = 1` ‚ÄĒ this is the first defining relator. -/
@[simp] theorem mk_T_sq :
    (PresentedGroup.mk relators (T * T) : PresentedGroup relators) = 1 := by
  exact PresentedGroup.one_of_mem (by simp [relators])

/-- Consequence: `mk T` is its own inverse in the presented group. -/
theorem mk_T_inv :
    (PresentedGroup.mk relators T)‚ĀĽ¬Ļ =
      (PresentedGroup.mk relators T : PresentedGroup relators) := by
  have h : PresentedGroup.mk relators T * PresentedGroup.mk relators T = 1 := by
    have := mk_T_sq
    simpa [map_mul] using this
  exact inv_eq_of_mul_eq_one_left h

/-- Consequence: `mk T‚ĀĽ¬Ļ = mk T`. -/
@[simp] theorem mk_T_inv_eq_mk_T :
    (PresentedGroup.mk relators T‚ĀĽ¬Ļ : PresentedGroup relators) = PresentedGroup.mk relators T := by
  rw [map_inv, mk_T_inv]

/-- Conjugation relation: in the presented group, `T A T = Aconj`. This is essentially the
definition of `Aconj`, made available through `T¬≤ = 1`. -/
theorem mk_T_A_T :
    (PresentedGroup.mk relators (T * A * T) : PresentedGroup relators) =
      PresentedGroup.mk relators Aconj := by
  show PresentedGroup.mk relators (T * A * T) = PresentedGroup.mk relators (T‚ĀĽ¬Ļ * A * T)
  simp [map_mul, mk_T_inv_eq_mk_T]

/-- Commutation of `T` and `A`: `T * A = Aconj * T`. -/
theorem mk_T_A :
    (PresentedGroup.mk relators (T * A) : PresentedGroup relators) =
      PresentedGroup.mk relators (Aconj * T) := by
  -- `Aconj * T = T‚ĀĽ¬Ļ * A * T * T = T * A * (T * T) = T * A`.
  show PresentedGroup.mk relators (T * A) = PresentedGroup.mk relators (T‚ĀĽ¬Ļ * A * T * T)
  simp [map_mul, mk_T_inv_eq_mk_T, mul_assoc,
    show (PresentedGroup.mk relators T) * PresentedGroup.mk relators T = 1 by
      have := mk_T_sq; simpa [map_mul] using this]

/-- Commutation of `T` and `Aconj`: `T * Aconj = A * T`. -/
theorem mk_T_Aconj :
    (PresentedGroup.mk relators (T * Aconj) : PresentedGroup relators) =
      PresentedGroup.mk relators (A * T) := by
  -- `T * Aconj = T * (T‚ĀĽ¬Ļ * A * T) = (T * T‚ĀĽ¬Ļ) * A * T = A * T`.
  show PresentedGroup.mk relators (T * (T‚ĀĽ¬Ļ * A * T)) = PresentedGroup.mk relators (A * T)
  simp [map_mul, mk_T_inv_eq_mk_T, ‚Üź mul_assoc,
    show (PresentedGroup.mk relators T) * PresentedGroup.mk relators T = 1 by
      have := mk_T_sq; simpa [map_mul] using this]

/-- The definition of `HallX = A‚ĀĽ¬Ļ * Aconj‚ĀĽ¬Ļ * A * Aconj` in the free group already tells us
that `Aconj * A = A * Aconj * HallX‚ĀĽ¬Ļ` there, and hence in every quotient. -/
theorem mk_Aconj_A :
    (PresentedGroup.mk relators (Aconj * A) : PresentedGroup relators) =
      PresentedGroup.mk relators (A * Aconj * HallX‚ĀĽ¬Ļ) := by
  have h : (Aconj * A : FreeGroup Generator) = A * Aconj * HallX‚ĀĽ¬Ļ := by
    show (T‚ĀĽ¬Ļ * A * T) * A = A * (T‚ĀĽ¬Ļ * A * T) *
        (A‚ĀĽ¬Ļ * (T‚ĀĽ¬Ļ * A * T)‚ĀĽ¬Ļ * A * (T‚ĀĽ¬Ļ * A * T))‚ĀĽ¬Ļ
    group
  rw [h]

/-- The definition of `HallY = A‚ĀĽ¬Ļ * HallX‚ĀĽ¬Ļ * A * HallX` in the free group already tells us
that `A * HallX = HallX * A * HallY` there, and hence in every quotient. -/
theorem mk_A_HallX :
    (PresentedGroup.mk relators (A * HallX) : PresentedGroup relators) =
      PresentedGroup.mk relators (HallX * A * HallY) := by
  have h : (A * HallX : FreeGroup Generator) = HallX * A * HallY := by
    change A * HallX = HallX * A * (A‚ĀĽ¬Ļ * HallX‚ĀĽ¬Ļ * A * HallX)
    group
  rw [h]

/-- Reverse form of `mk_A_HallX`: `mk (HallX * A) = mk (A * HallX * HallY‚ĀĽ¬Ļ)`. -/
theorem mk_HallX_A :
    (PresentedGroup.mk relators (HallX * A) : PresentedGroup relators) =
      PresentedGroup.mk relators (A * HallX * HallY‚ĀĽ¬Ļ) := by
  have h : (HallX * A : FreeGroup Generator) = A * HallX * HallY‚ĀĽ¬Ļ := by
    change HallX * A = A * HallX * (A‚ĀĽ¬Ļ * HallX‚ĀĽ¬Ļ * A * HallX)‚ĀĽ¬Ļ
    group
  rw [h]

/-- Reverse form of `mk_Aconj_A`: `mk (A * Aconj) = mk (Aconj * A * HallX)`. -/
theorem mk_A_Aconj :
    (PresentedGroup.mk relators (A * Aconj) : PresentedGroup relators) =
      PresentedGroup.mk relators (Aconj * A * HallX) := by
  have h : (A * Aconj : FreeGroup Generator) = Aconj * A * HallX := by
    show A * (T‚ĀĽ¬Ļ * A * T) = (T‚ĀĽ¬Ļ * A * T) * A *
        (A‚ĀĽ¬Ļ * (T‚ĀĽ¬Ļ * A * T)‚ĀĽ¬Ļ * A * (T‚ĀĽ¬Ļ * A * T))
    group
  rw [h]

/-- Moving `A‚ĀĽ¬Ļ` past `Aconj‚ĀĽ¬Ļ`: `mk (Aconj‚ĀĽ¬Ļ * A‚ĀĽ¬Ļ) = mk (HallX‚ĀĽ¬Ļ * A‚ĀĽ¬Ļ * Aconj‚ĀĽ¬Ļ)`.

Free-group inverse of `mk_A_Aconj`. -/
theorem mk_Aconjinv_Ainv :
    (PresentedGroup.mk relators (Aconj‚ĀĽ¬Ļ * A‚ĀĽ¬Ļ) : PresentedGroup relators) =
      PresentedGroup.mk relators (HallX‚ĀĽ¬Ļ * A‚ĀĽ¬Ļ * Aconj‚ĀĽ¬Ļ) := by
  have h : (Aconj‚ĀĽ¬Ļ * A‚ĀĽ¬Ļ : FreeGroup Generator) = HallX‚ĀĽ¬Ļ * A‚ĀĽ¬Ļ * Aconj‚ĀĽ¬Ļ := by
    show (T‚ĀĽ¬Ļ * A * T)‚ĀĽ¬Ļ * A‚ĀĽ¬Ļ =
        (A‚ĀĽ¬Ļ * (T‚ĀĽ¬Ļ * A * T)‚ĀĽ¬Ļ * A * (T‚ĀĽ¬Ļ * A * T))‚ĀĽ¬Ļ * A‚ĀĽ¬Ļ * (T‚ĀĽ¬Ļ * A * T)‚ĀĽ¬Ļ
    group
  rw [h]

/-- `mk` sends the third-relator commutator `‚ĀÖC, A‚ĀÜ` to `1`. -/
theorem mk_commutator_C_A :
    (PresentedGroup.mk relators ‚ĀÖC, A‚ĀÜ : PresentedGroup relators) = 1 :=
  PresentedGroup.mk_eq_one_iff.mpr <|
    Subgroup.subset_normalClosure (by
      show ‚ĀÖC, A‚ĀÜ ‚ąą ({T * T, C * (‚ĀÖAconj, ‚ĀÖA, Aconj‚ĀÜ‚ĀÜ)‚ĀĽ¬Ļ, ‚ĀÖC, A‚ĀÜ, ‚ĀÖC, Aconj‚ĀÜ}
        : Set (FreeGroup Generator))
      simp)

/-- `mk` sends the fourth-relator commutator `‚ĀÖC, Aconj‚ĀÜ` to `1`. -/
theorem mk_commutator_C_Aconj :
    (PresentedGroup.mk relators ‚ĀÖC, Aconj‚ĀÜ : PresentedGroup relators) = 1 :=
  PresentedGroup.mk_eq_one_iff.mpr <|
    Subgroup.subset_normalClosure (by
      show ‚ĀÖC, Aconj‚ĀÜ ‚ąą ({T * T, C * (‚ĀÖAconj, ‚ĀÖA, Aconj‚ĀÜ‚ĀÜ)‚ĀĽ¬Ļ, ‚ĀÖC, A‚ĀÜ, ‚ĀÖC, Aconj‚ĀÜ}
        : Set (FreeGroup Generator))
      simp)

/-- Centrality of `mk C` against `mk A`: `mk (C * A) = mk (A * C)`. -/
theorem mk_C_A_comm :
    (PresentedGroup.mk relators (C * A) : PresentedGroup relators) =
      PresentedGroup.mk relators (A * C) := by
  have hcomm' :
      ‚ĀÖ(PresentedGroup.mk relators C : PresentedGroup relators),
        PresentedGroup.mk relators A‚ĀÜ = 1 := by
    have := mk_commutator_C_A
    simpa [map_commutatorElement] using this
  have hcomm := commutatorElement_eq_one_iff_commute.mp hcomm'
  show (PresentedGroup.mk relators C) * PresentedGroup.mk relators A =
    PresentedGroup.mk relators A * PresentedGroup.mk relators C
  exact hcomm

/-- Centrality of `mk C` against `mk Aconj`: `mk (C * Aconj) = mk (Aconj * C)`. -/
theorem mk_C_Aconj_comm :
    (PresentedGroup.mk relators (C * Aconj) : PresentedGroup relators) =
      PresentedGroup.mk relators (Aconj * C) := by
  have hcomm' :
      ‚ĀÖ(PresentedGroup.mk relators C : PresentedGroup relators),
        PresentedGroup.mk relators Aconj‚ĀÜ = 1 := by
    have := mk_commutator_C_Aconj
    simpa [map_commutatorElement] using this
  have hcomm := commutatorElement_eq_one_iff_commute.mp hcomm'
  show (PresentedGroup.mk relators C) * PresentedGroup.mk relators Aconj =
    PresentedGroup.mk relators Aconj * PresentedGroup.mk relators C
  exact hcomm

/-!
### Shifts through the mathlib commutator `HallXC := ‚ĀÖA, Aconj‚ĀÜ`

The mathlib commutator `‚ĀÖA, Aconj‚ĀÜ = A¬∑Aconj¬∑A‚ĀĽ¬Ļ¬∑Aconj‚ĀĽ¬Ļ` is easier to shift past `A` and
`Aconj` than the Hall commutator `HallX`, because the commutator `[A, HallXC]_mathlib` is
exactly `C` by definition, and `C` is central. These shift lemmas are the building blocks for
the class-3 nilpotent structure of the presented group.
-/

/-- Free-group identity: `HallXC ¬∑ A = C‚ĀĽ¬Ļ ¬∑ A ¬∑ HallXC`. This is immediate from
`C = A ¬∑ HallXC ¬∑ A‚ĀĽ¬Ļ ¬∑ HallXC‚ĀĽ¬Ļ` (definition of `C = ‚ĀÖA, HallXC‚ĀÜ_mathlib`). -/
theorem freeGroup_HallXC_A :
    (‚ĀÖA, Aconj‚ĀÜ * A : FreeGroup Generator) = (‚ĀÖA, ‚ĀÖA, Aconj‚ĀÜ‚ĀÜ)‚ĀĽ¬Ļ * A * ‚ĀÖA, Aconj‚ĀÜ := by
  show (A * Aconj * A‚ĀĽ¬Ļ * Aconj‚ĀĽ¬Ļ) * A =
       (A * (A * Aconj * A‚ĀĽ¬Ļ * Aconj‚ĀĽ¬Ļ) * A‚ĀĽ¬Ļ * (A * Aconj * A‚ĀĽ¬Ļ * Aconj‚ĀĽ¬Ļ)‚ĀĽ¬Ļ)‚ĀĽ¬Ļ * A *
         (A * Aconj * A‚ĀĽ¬Ļ * Aconj‚ĀĽ¬Ļ)
  group

/-- Free-group identity: `A ¬∑ HallXC = C ¬∑ HallXC ¬∑ A`. -/
theorem freeGroup_A_HallXC :
    (A * ‚ĀÖA, Aconj‚ĀÜ : FreeGroup Generator) = ‚ĀÖA, ‚ĀÖA, Aconj‚ĀÜ‚ĀÜ * ‚ĀÖA, Aconj‚ĀÜ * A := by
  show A * (A * Aconj * A‚ĀĽ¬Ļ * Aconj‚ĀĽ¬Ļ) =
       (A * (A * Aconj * A‚ĀĽ¬Ļ * Aconj‚ĀĽ¬Ļ) * A‚ĀĽ¬Ļ * (A * Aconj * A‚ĀĽ¬Ļ * Aconj‚ĀĽ¬Ļ)‚ĀĽ¬Ļ) *
         (A * Aconj * A‚ĀĽ¬Ļ * Aconj‚ĀĽ¬Ļ) * A
  group

/-- Free-group identity: `Aconj ¬∑ HallXC = ‚ĀÖAconj, HallXC‚ĀÜ ¬∑ HallXC ¬∑ Aconj`. -/
theorem freeGroup_Aconj_HallXC :
    (Aconj * ‚ĀÖA, Aconj‚ĀÜ : FreeGroup Generator) =
      ‚ĀÖAconj, ‚ĀÖA, Aconj‚ĀÜ‚ĀÜ * ‚ĀÖA, Aconj‚ĀÜ * Aconj := by
  show (T‚ĀĽ¬Ļ * A * T) * (A * Aconj * A‚ĀĽ¬Ļ * Aconj‚ĀĽ¬Ļ) =
       ((T‚ĀĽ¬Ļ * A * T) * (A * Aconj * A‚ĀĽ¬Ļ * Aconj‚ĀĽ¬Ļ) * (T‚ĀĽ¬Ļ * A * T)‚ĀĽ¬Ļ *
           (A * Aconj * A‚ĀĽ¬Ļ * Aconj‚ĀĽ¬Ļ)‚ĀĽ¬Ļ) *
         (A * Aconj * A‚ĀĽ¬Ļ * Aconj‚ĀĽ¬Ļ) * (T‚ĀĽ¬Ļ * A * T)
  group

/-- The second relator, applied: `mk C = mk ‚ĀÖAconj, ‚ĀÖA, Aconj‚ĀÜ‚ĀÜ` in the presented group. -/
theorem mk_C_eq_mk_Engel :
    (PresentedGroup.mk relators C : PresentedGroup relators) =
      PresentedGroup.mk relators ‚ĀÖAconj, ‚ĀÖA, Aconj‚ĀÜ‚ĀÜ := by
  have hrel :
      (PresentedGroup.mk relators (C * (‚ĀÖAconj, ‚ĀÖA, Aconj‚ĀÜ‚ĀÜ)‚ĀĽ¬Ļ) :
          PresentedGroup relators) = 1 :=
    PresentedGroup.mk_eq_one_iff.mpr <|
      Subgroup.subset_normalClosure (by
        show C * (‚ĀÖAconj, ‚ĀÖA, Aconj‚ĀÜ‚ĀÜ)‚ĀĽ¬Ļ ‚ąą
          ({T * T, C * (‚ĀÖAconj, ‚ĀÖA, Aconj‚ĀÜ‚ĀÜ)‚ĀĽ¬Ļ, ‚ĀÖC, A‚ĀÜ, ‚ĀÖC, Aconj‚ĀÜ}
            : Set (FreeGroup Generator))
        simp)
  have := hrel
  rw [map_mul, map_inv, mul_inv_eq_one] at this
  exact this

/-- Inverse form of `mk_Aconj_A`: `mk (A‚ĀĽ¬Ļ * Aconj‚ĀĽ¬Ļ) = mk (HallX * Aconj‚ĀĽ¬Ļ * A‚ĀĽ¬Ļ)`. -/
theorem mk_Ainv_Aconjinv :
    (PresentedGroup.mk relators (A‚ĀĽ¬Ļ * Aconj‚ĀĽ¬Ļ) : PresentedGroup relators) =
      PresentedGroup.mk relators (HallX * Aconj‚ĀĽ¬Ļ * A‚ĀĽ¬Ļ) := by
  have h : (A‚ĀĽ¬Ļ * Aconj‚ĀĽ¬Ļ : FreeGroup Generator) = HallX * Aconj‚ĀĽ¬Ļ * A‚ĀĽ¬Ļ := by
    show A‚ĀĽ¬Ļ * (T‚ĀĽ¬Ļ * A * T)‚ĀĽ¬Ļ =
      (A‚ĀĽ¬Ļ * (T‚ĀĽ¬Ļ * A * T)‚ĀĽ¬Ļ * A * (T‚ĀĽ¬Ļ * A * T)) * (T‚ĀĽ¬Ļ * A * T)‚ĀĽ¬Ļ * A‚ĀĽ¬Ļ
    group
  rw [h]

/-- Inverse form of `mk_A_HallX`: `mk (HallX‚ĀĽ¬Ļ * A‚ĀĽ¬Ļ) = mk (HallY‚ĀĽ¬Ļ * A‚ĀĽ¬Ļ * HallX‚ĀĽ¬Ļ)`. -/
theorem mk_HallXinv_Ainv :
    (PresentedGroup.mk relators (HallX‚ĀĽ¬Ļ * A‚ĀĽ¬Ļ) : PresentedGroup relators) =
      PresentedGroup.mk relators (HallY‚ĀĽ¬Ļ * A‚ĀĽ¬Ļ * HallX‚ĀĽ¬Ļ) := by
  have h : (HallX‚ĀĽ¬Ļ * A‚ĀĽ¬Ļ : FreeGroup Generator) = HallY‚ĀĽ¬Ļ * A‚ĀĽ¬Ļ * HallX‚ĀĽ¬Ļ := by
    change HallX‚ĀĽ¬Ļ * A‚ĀĽ¬Ļ =
      (A‚ĀĽ¬Ļ * HallX‚ĀĽ¬Ļ * A * HallX)‚ĀĽ¬Ļ * A‚ĀĽ¬Ļ * HallX‚ĀĽ¬Ļ
    group
  rw [h]

/-- `mk C` commutes with `mk A‚ĀĽ¬Ļ`: `mk (C * A‚ĀĽ¬Ļ) = mk (A‚ĀĽ¬Ļ * C)`. -/
theorem mk_C_Ainv_comm :
    (PresentedGroup.mk relators (C * A‚ĀĽ¬Ļ) : PresentedGroup relators) =
      PresentedGroup.mk relators (A‚ĀĽ¬Ļ * C) := by
  have hcomm : Commute (PresentedGroup.mk relators C : PresentedGroup relators)
      (PresentedGroup.mk relators A) := mk_C_A_comm
  have hinv := hcomm.inv_right
  show (PresentedGroup.mk relators C) * (PresentedGroup.mk relators A‚ĀĽ¬Ļ) =
    (PresentedGroup.mk relators A‚ĀĽ¬Ļ) * PresentedGroup.mk relators C
  rw [map_inv]; exact hinv

/-- `mk C` commutes with `mk Aconj‚ĀĽ¬Ļ`: `mk (C * Aconj‚ĀĽ¬Ļ) = mk (Aconj‚ĀĽ¬Ļ * C)`. -/
theorem mk_C_Aconjinv_comm :
    (PresentedGroup.mk relators (C * Aconj‚ĀĽ¬Ļ) : PresentedGroup relators) =
      PresentedGroup.mk relators (Aconj‚ĀĽ¬Ļ * C) := by
  have hcomm : Commute (PresentedGroup.mk relators C : PresentedGroup relators)
      (PresentedGroup.mk relators Aconj) := mk_C_Aconj_comm
  have hinv := hcomm.inv_right
  show (PresentedGroup.mk relators C) * (PresentedGroup.mk relators Aconj‚ĀĽ¬Ļ) =
    (PresentedGroup.mk relators Aconj‚ĀĽ¬Ļ) * PresentedGroup.mk relators C
  rw [map_inv]; exact hinv

/-- `mk C` commutes with `mk HallXC := mk ‚ĀÖA, Aconj‚ĀÜ`, since `HallXC` is a word in `A, Aconj`
and `mk C` commutes with both. -/
theorem mk_C_HallXC_comm :
    Commute (PresentedGroup.mk relators C : PresentedGroup relators)
      (PresentedGroup.mk relators ‚ĀÖA, Aconj‚ĀÜ) := by
  have h : (PresentedGroup.mk relators ‚ĀÖA, Aconj‚ĀÜ : PresentedGroup relators) =
      PresentedGroup.mk relators A * PresentedGroup.mk relators Aconj *
      (PresentedGroup.mk relators A)‚ĀĽ¬Ļ * (PresentedGroup.mk relators Aconj)‚ĀĽ¬Ļ := by
    show PresentedGroup.mk relators (A * Aconj * A‚ĀĽ¬Ļ * Aconj‚ĀĽ¬Ļ) = _
    rw [map_mul, map_mul, map_mul, map_inv, map_inv]
  rw [h]
  have ha : Commute (PresentedGroup.mk relators C : PresentedGroup relators)
      (PresentedGroup.mk relators A) := mk_C_A_comm
  have hb : Commute (PresentedGroup.mk relators C : PresentedGroup relators)
      (PresentedGroup.mk relators Aconj) := mk_C_Aconj_comm
  exact ((ha.mul_right hb).mul_right ha.inv_right).mul_right hb.inv_right

/-!
### Shift lemmas for `HallXC := ‚ĀÖA, Aconj‚ĀÜ`

Using the free-group identities `freeGroup_HallXC_A`, `freeGroup_A_HallXC`,
`freeGroup_Aconj_HallXC` (which express `HallXC ¬∑ A`, `A ¬∑ HallXC`, `Aconj ¬∑ HallXC` as
"corrections" involving `C`), plus centrality of `C` (against `A`, `Aconj`, `HallXC`), we obtain
clean shift laws in the presented group.
-/

/-- Shift of `HallXC` past `A`: `mk (HallXC ¬∑ A) = mk (A ¬∑ HallXC ¬∑ C‚ĀĽ¬Ļ)`. -/
theorem mk_HallXC_A_shift :
    (PresentedGroup.mk relators (‚ĀÖA, Aconj‚ĀÜ * A) : PresentedGroup relators) =
      PresentedGroup.mk relators (A * ‚ĀÖA, Aconj‚ĀÜ * C‚ĀĽ¬Ļ) := by
  rw [freeGroup_HallXC_A]
  set a := (PresentedGroup.mk relators A : PresentedGroup relators)
  set xc := (PresentedGroup.mk relators ‚ĀÖA, Aconj‚ĀÜ : PresentedGroup relators)
  set c := (PresentedGroup.mk relators C : PresentedGroup relators)
  have hcA : Commute c a := mk_C_A_comm
  have hcXC : Commute c xc := mk_C_HallXC_comm
  show c‚ĀĽ¬Ļ * a * xc = a * xc * c‚ĀĽ¬Ļ
  have h1 : c‚ĀĽ¬Ļ * a = a * c‚ĀĽ¬Ļ := hcA.inv_left.eq
  have h2 : c‚ĀĽ¬Ļ * xc = xc * c‚ĀĽ¬Ļ := hcXC.inv_left.eq
  calc c‚ĀĽ¬Ļ * a * xc = a * c‚ĀĽ¬Ļ * xc := by rw [h1]
    _ = a * (c‚ĀĽ¬Ļ * xc) := by rw [mul_assoc]
    _ = a * (xc * c‚ĀĽ¬Ļ) := by rw [h2]
    _ = a * xc * c‚ĀĽ¬Ļ := by rw [mul_assoc]

/-- Shift of `A` past `HallXC`: `mk (A ¬∑ HallXC) = mk (HallXC ¬∑ A ¬∑ C)`. -/
theorem mk_A_HallXC_shift :
    (PresentedGroup.mk relators (A * ‚ĀÖA, Aconj‚ĀÜ) : PresentedGroup relators) =
      PresentedGroup.mk relators (‚ĀÖA, Aconj‚ĀÜ * A * C) := by
  rw [freeGroup_A_HallXC]
  set a := (PresentedGroup.mk relators A : PresentedGroup relators)
  set xc := (PresentedGroup.mk relators ‚ĀÖA, Aconj‚ĀÜ : PresentedGroup relators)
  set c := (PresentedGroup.mk relators C : PresentedGroup relators)
  have hcA : Commute c a := mk_C_A_comm
  have hcXC : Commute c xc := mk_C_HallXC_comm
  show c * xc * a = xc * a * c
  calc c * xc * a = xc * c * a := by rw [hcXC.eq]
    _ = xc * (c * a) := by rw [mul_assoc]
    _ = xc * (a * c) := by rw [hcA.eq]
    _ = xc * a * c := by rw [mul_assoc]

/-- Shift of `Aconj` past `HallXC`: `mk (Aconj ¬∑ HallXC) = mk (HallXC ¬∑ Aconj ¬∑ C)`.

Uses `freeGroup_Aconj_HallXC`, `mk_C_eq_mk_Engel` (identifying `mk ‚ĀÖAconj, HallXC‚ĀÜ` with `mk C`),
and centrality of `C`. -/
theorem mk_Aconj_HallXC_shift :
    (PresentedGroup.mk relators (Aconj * ‚ĀÖA, Aconj‚ĀÜ) : PresentedGroup relators) =
      PresentedGroup.mk relators (‚ĀÖA, Aconj‚ĀÜ * Aconj * C) := by
  rw [freeGroup_Aconj_HallXC]
  set b := (PresentedGroup.mk relators Aconj : PresentedGroup relators)
  set xc := (PresentedGroup.mk relators ‚ĀÖA, Aconj‚ĀÜ : PresentedGroup relators)
  set c := (PresentedGroup.mk relators C : PresentedGroup relators)
  have hcB : Commute c b := mk_C_Aconj_comm
  have hcXC : Commute c xc := mk_C_HallXC_comm
  have hEngel :
      (PresentedGroup.mk relators ‚ĀÖAconj, ‚ĀÖA, Aconj‚ĀÜ‚ĀÜ : PresentedGroup relators) = c :=
    mk_C_eq_mk_Engel.symm
  show PresentedGroup.mk relators ‚ĀÖAconj, ‚ĀÖA, Aconj‚ĀÜ‚ĀÜ * xc * b = xc * b * c
  rw [hEngel]
  calc c * xc * b = xc * c * b := by rw [hcXC.eq]
    _ = xc * (c * b) := by rw [mul_assoc]
    _ = xc * (b * c) := by rw [hcB.eq]
    _ = xc * b * c := by rw [mul_assoc]

/-- `T` conjugation on `HallX` returns `HallX‚ĀĽ¬Ļ` at the presented-group level.

This reflects the fact that `T` acts on the abelianized commutator layer by swapping
`A ‚ÜĒ Aconj`, and hence sending `X = ‚ĀÖA‚ĀĽ¬Ļ, Aconj‚ĀĽ¬Ļ‚ĀÜ` to its inverse `‚ĀÖAconj‚ĀĽ¬Ļ, A‚ĀĽ¬Ļ‚ĀÜ`. -/
theorem mk_T_HallX_T :
    (PresentedGroup.mk relators (T * HallX * T) : PresentedGroup relators) =
      PresentedGroup.mk relators HallX‚ĀĽ¬Ļ := by
  set t := (PresentedGroup.mk relators T : PresentedGroup relators)
  set a := (PresentedGroup.mk relators A : PresentedGroup relators)
  set b := (PresentedGroup.mk relators Aconj : PresentedGroup relators)
  have htt : t * t = 1 := by
    have := mk_T_sq
    have hmul : (PresentedGroup.mk relators (T * T) : PresentedGroup relators) = t * t :=
      map_mul _ _ _
    rw [hmul] at this; exact this
  have ht_inv : t‚ĀĽ¬Ļ = t := inv_eq_of_mul_eq_one_left htt
  have hTAT : t * a * t = b := by
    have := mk_T_A_T
    have h1 : (PresentedGroup.mk relators (T * A * T) : PresentedGroup relators) = t * a * t := by
      rw [show (T * A * T : FreeGroup Generator) = T * A * T from rfl]
      rw [map_mul, map_mul]
    rw [h1] at this; exact this
  have hTBT : t * b * t = a := by
    have h : t * (t * a * t) * t = t * b * t := by rw [hTAT]
    have hcancel : t * (t * a * t) * t = a := by
      have step1 : t * (t * a * t) * t = (t * t) * a * (t * t) := by
        simp [mul_assoc]
      rw [step1, htt, one_mul, mul_one]
    rw [hcancel] at h; exact h.symm
  -- Inverse-swap identities: `t * a‚ĀĽ¬Ļ * t = b‚ĀĽ¬Ļ`, `t * b‚ĀĽ¬Ļ * t = a‚ĀĽ¬Ļ`.
  have hTAinvT : t * a‚ĀĽ¬Ļ * t = b‚ĀĽ¬Ļ := by
    have : (t * a * t)‚ĀĽ¬Ļ = b‚ĀĽ¬Ļ := congrArg (¬∑‚ĀĽ¬Ļ) hTAT
    rw [mul_inv_rev, mul_inv_rev, ht_inv] at this
    -- this : t * (a‚ĀĽ¬Ļ * t) = b‚ĀĽ¬Ļ, need associativity fix
    rw [‚Üź mul_assoc] at this; exact this
  have hTBinvT : t * b‚ĀĽ¬Ļ * t = a‚ĀĽ¬Ļ := by
    have : (t * b * t)‚ĀĽ¬Ļ = a‚ĀĽ¬Ļ := congrArg (¬∑‚ĀĽ¬Ļ) hTBT
    rw [mul_inv_rev, mul_inv_rev, ht_inv] at this
    rw [‚Üź mul_assoc] at this; exact this
  -- Expand LHS and RHS in terms of `a, b, t`.
  have hlhs :
      (PresentedGroup.mk relators (T * HallX * T) : PresentedGroup relators)
        = t * (a‚ĀĽ¬Ļ * b‚ĀĽ¬Ļ * a * b) * t := by
    show PresentedGroup.mk relators (T * (A‚ĀĽ¬Ļ * Aconj‚ĀĽ¬Ļ * A * Aconj) * T) =
      t * (a‚ĀĽ¬Ļ * b‚ĀĽ¬Ļ * a * b) * t
    rw [map_mul, map_mul, map_mul, map_mul, map_mul, map_inv, map_inv]
  have hrhs :
      (PresentedGroup.mk relators HallX‚ĀĽ¬Ļ : PresentedGroup relators)
        = b‚ĀĽ¬Ļ * a‚ĀĽ¬Ļ * b * a := by
    show PresentedGroup.mk relators (Aconj‚ĀĽ¬Ļ * A‚ĀĽ¬Ļ * Aconj * A) = b‚ĀĽ¬Ļ * a‚ĀĽ¬Ļ * b * a
    rw [map_mul, map_mul, map_mul, map_inv, map_inv]
  rw [hlhs, hrhs]
  -- The core computation: insert `t * t = 1` between each factor and apply the swaps.
  have insert :
      t * (a‚ĀĽ¬Ļ * b‚ĀĽ¬Ļ * a * b) * t =
        (t * a‚ĀĽ¬Ļ * t) * (t * b‚ĀĽ¬Ļ * t) * (t * a * t) * (t * b * t) := by
    have e1 : t * (a‚ĀĽ¬Ļ * b‚ĀĽ¬Ļ * a * b) * t =
        t * a‚ĀĽ¬Ļ * (t * t) * b‚ĀĽ¬Ļ * (t * t) * a * (t * t) * b * t := by
      rw [htt]; group
    rw [e1]; group
  rw [insert, hTAinvT, hTBinvT, hTAT, hTBT]

/-- T-conjugation on `HallY`: at the presented-group level,
`T * HallY * T = Aconj‚ĀĽ¬Ļ * HallX * Aconj * HallX‚ĀĽ¬Ļ`.

This is the analog of `mk_T_HallX_T`, expressing the effect of T-conjugation on the
Hall-convention class-3 commutator `HallY = A‚ĀĽ¬Ļ * HallX‚ĀĽ¬Ļ * A * HallX`. It follows from
inserting `T¬≤ = 1` between the four factors of `HallY` and applying the swaps
`T * A * T = Aconj`, `T * A‚ĀĽ¬Ļ * T = Aconj‚ĀĽ¬Ļ`, `T * HallX * T = HallX‚ĀĽ¬Ļ`,
`T * HallX‚ĀĽ¬Ļ * T = HallX`. -/
theorem mk_T_HallY_T :
    (PresentedGroup.mk relators (T * HallY * T) : PresentedGroup relators) =
      PresentedGroup.mk relators (Aconj‚ĀĽ¬Ļ * HallX * Aconj * HallX‚ĀĽ¬Ļ) := by
  set t := (PresentedGroup.mk relators T : PresentedGroup relators)
  set a := (PresentedGroup.mk relators A : PresentedGroup relators)
  set b := (PresentedGroup.mk relators Aconj : PresentedGroup relators)
  set x := (PresentedGroup.mk relators HallX : PresentedGroup relators)
  have htt : t * t = 1 := by
    have := mk_T_sq
    have hmul : (PresentedGroup.mk relators (T * T) : PresentedGroup relators) = t * t :=
      map_mul _ _ _
    rw [hmul] at this; exact this
  -- Four T-conjugation identities.
  have hTAT : t * a * t = b := by
    have := mk_T_A_T
    have h1 : (PresentedGroup.mk relators (T * A * T) : PresentedGroup relators) = t * a * t := by
      rw [map_mul, map_mul]
    rw [h1] at this; exact this
  have hTAinvT : t * a‚ĀĽ¬Ļ * t = b‚ĀĽ¬Ļ := by
    have : (t * a * t)‚ĀĽ¬Ļ = b‚ĀĽ¬Ļ := congrArg (¬∑‚ĀĽ¬Ļ) hTAT
    have ht_inv : t‚ĀĽ¬Ļ = t := inv_eq_of_mul_eq_one_left htt
    rw [mul_inv_rev, mul_inv_rev, ht_inv] at this
    rw [‚Üź mul_assoc] at this; exact this
  have hTHXT : t * x * t = x‚ĀĽ¬Ļ := by
    have := mk_T_HallX_T
    have h1 : (PresentedGroup.mk relators (T * HallX * T) : PresentedGroup relators)
        = t * x * t := by
      rw [map_mul, map_mul]
    have h2 : (PresentedGroup.mk relators HallX‚ĀĽ¬Ļ : PresentedGroup relators) = x‚ĀĽ¬Ļ := by
      rw [map_inv]
    rw [h1, h2] at this; exact this
  have hTHXinvT : t * x‚ĀĽ¬Ļ * t = x := by
    have : (t * x * t)‚ĀĽ¬Ļ = (x‚ĀĽ¬Ļ : PresentedGroup relators)‚ĀĽ¬Ļ := congrArg (¬∑‚ĀĽ¬Ļ) hTHXT
    have ht_inv : t‚ĀĽ¬Ļ = t := inv_eq_of_mul_eq_one_left htt
    rw [mul_inv_rev, mul_inv_rev, ht_inv, inv_inv] at this
    rw [‚Üź mul_assoc] at this; exact this
  -- Expand LHS in `a, b, x, t`.
  have hlhs :
      (PresentedGroup.mk relators (T * HallY * T) : PresentedGroup relators)
        = t * (a‚ĀĽ¬Ļ * x‚ĀĽ¬Ļ * a * x) * t := by
    show PresentedGroup.mk relators (T * (A‚ĀĽ¬Ļ * HallX‚ĀĽ¬Ļ * A * HallX) * T) =
      t * (a‚ĀĽ¬Ļ * x‚ĀĽ¬Ļ * a * x) * t
    rw [map_mul, map_mul, map_mul, map_mul, map_mul, map_inv, map_inv]
  have hrhs :
      (PresentedGroup.mk relators (Aconj‚ĀĽ¬Ļ * HallX * Aconj * HallX‚ĀĽ¬Ļ)
          : PresentedGroup relators)
        = b‚ĀĽ¬Ļ * x * b * x‚ĀĽ¬Ļ := by
    rw [map_mul, map_mul, map_mul, map_inv, map_inv]
  rw [hlhs, hrhs]
  -- Insert `t * t = 1` between the four factors and apply the swaps.
  have insert :
      t * (a‚ĀĽ¬Ļ * x‚ĀĽ¬Ļ * a * x) * t =
        (t * a‚ĀĽ¬Ļ * t) * (t * x‚ĀĽ¬Ļ * t) * (t * a * t) * (t * x * t) := by
    have e1 : t * (a‚ĀĽ¬Ļ * x‚ĀĽ¬Ļ * a * x) * t =
        t * a‚ĀĽ¬Ļ * (t * t) * x‚ĀĽ¬Ļ * (t * t) * a * (t * t) * x * t := by
      rw [htt]; group
    rw [e1]; group
  rw [insert, hTAinvT, hTHXinvT, hTAT, hTHXT]

/-- Theorem 4 of Bodart, recorded as an internal-facing axiom to be formalized.

It states that the virtually Engel group above has intermediate geodesic growth with respect to
the generating alphabet `S = {a, a‚ĀĽ¬Ļ, t}`, i.e.\ `ő≥(n) ‚Čć exp(n^(3/5) log n)`. Discharging this
axiom is one of the three remaining internal steps for an unconditional positive answer to
Br√∂nnimann's Question 3. -/
axiom theorem_4 : theorem_4_statement

/-!
## Word problem via the coordinate map

The classical word-problem witness is derived from a single sharper algebraic fact, namely
injectivity of `toCoordGroup`. Given injectivity, the coordinate model ‚ÄĒ which has decidable
equality since it is a semidirect product of two types with decidable equality ‚ÄĒ furnishes a
decision procedure for equality in the presented group.

Injectivity itself is the remaining algebraic step. It amounts to the Hall normal-form theorem
inside `PresentedGroup relators`: every element of the presented group is equal to
`PresentedGroup.mk (coordLatticeWord g)` for a unique lattice point `g` (paired with a symmetry
letter), and `coordLatticeWord_spec` above shows that distinct lattice points map to distinct
coordinates. Any single left inverse of `toCoordGroup` ‚ÄĒ for example the reconstruction map
sending a coordinate to `mk` of its Hall word ‚ÄĒ would witness injectivity, and this is precisely
what the ongoing algebraic groundwork (the Hall normal-form reconstruction, the lattice
congruence subgroup, the coordinate model of every relator) is designed to support. -/

/-!
## Image of the coordinate map lies in the lattice

The presentation generators land in `coordLattice`, and `coordLattice` is a subgroup, so the
image of every word in the presented group lies in `coordLattice`.
-/

/-- The coordinate homomorphism factored through the lattice subgroup. -/
def toCoordLattice : FreeGroup Generator ‚Üí* coordLattice :=
  FreeGroup.lift coordLatticeGenerator

theorem toCoordLattice_val (w : FreeGroup Generator) :
    (toCoordLattice w).1 = FreeGroup.lift coordGenerator w := by
  refine FreeGroup.induction_on w ?_ ?_ ?_ ?_
  ¬∑ simp [toCoordLattice]
  ¬∑ intro g; cases g <;> simp [toCoordLattice, coordLatticeGenerator, coordGenerator]
  ¬∑ intro g; cases g <;> simp [toCoordLattice, coordLatticeGenerator, coordGenerator]
  ¬∑ intro x y hx hy
    simp [map_mul, hx, hy]

/-- The image of any word in the free group lies in the coordinate lattice. -/
theorem coordGenerator_lift_mem_lattice (w : FreeGroup Generator) :
    FreeGroup.lift coordGenerator w ‚ąą coordLattice := by
  rw [‚Üź toCoordLattice_val]
  exact (toCoordLattice w).2

/-- The image of any presented-group element lies in the coordinate lattice. -/
theorem toCoordGroup_mem_lattice (x : PresentedGroup relators) :
    toCoordGroup x ‚ąą coordLattice := by
  induction x with
  | H z =>
    have h := coordGenerator_lift_mem_lattice z
    simpa [toCoordGroup, PresentedGroup.toGroup] using h

/-!
## A canonical set-theoretic retract

Every element of the coordinate lattice can be reconstructed as `mk` of an explicit Hall normal
form word. The following retract lifts this reconstruction to `CoordGroup`, sending elements
outside the lattice to `1`. Injectivity of `toCoordGroup` is equivalent to `retract` being a
left inverse of `toCoordGroup`.
-/

/-- The set-theoretic retract from the coordinate model back to the presented group. On lattice
elements it is the `mk` of the Hall normal form; elsewhere it is arbitrarily set to `1`. -/
noncomputable def retract (g : CoordGroup) : PresentedGroup relators := by
  classical exact
    if h : g ‚ąą coordLattice then
      PresentedGroup.mk relators (coordLatticeWord ‚ü®g, h‚ü©)
    else 1

theorem retract_of_mem_lattice {g : CoordGroup} (h : g ‚ąą coordLattice) :
    retract g = PresentedGroup.mk relators (coordLatticeWord ‚ü®g, h‚ü©) := by
  simp [retract, dif_pos h]

/-- Injectivity of `toCoordGroup` is equivalent to `retract` being a left inverse.

Given `retract ‚ąė toCoordGroup = id`, `toCoordGroup` is injective. Conversely, given
injectivity, `retract ‚ąė toCoordGroup` and `id` agree on lattice elements after applying
`toCoordGroup`, which is enough to derive the left-inverse property from `coordLatticeWord_spec`.

This reduces the remaining internal step to a single algebraic identity in
`PresentedGroup relators`, namely that for every word `w`,
`mk (coordLatticeWord (toCoordGroup (mk w))) = mk w`. -/
theorem toCoordGroup_injective_iff_retract :
    Function.Injective toCoordGroup ‚ÜĒ
      Function.LeftInverse (retract : CoordGroup ‚Üí PresentedGroup relators) toCoordGroup := by
  refine ‚ü®?_, Function.LeftInverse.injective‚ü©
  intro hinj x
  have hmem : toCoordGroup x ‚ąą coordLattice := toCoordGroup_mem_lattice x
  rw [retract_of_mem_lattice hmem]
  apply hinj
  have hspec := coordLatticeWord_spec ‚ü®toCoordGroup x, hmem‚ü©
  have hlift :
      toCoordGroup
          (PresentedGroup.mk relators
              (coordLatticeWord ‚ü®toCoordGroup x, hmem‚ü©)) =
        FreeGroup.lift coordGenerator
          (coordLatticeWord ‚ü®toCoordGroup x, hmem‚ü©) := rfl
  rw [hlift, hspec]

/-!
### Base cases of the retract identity

The retract identity `retract (toCoordGroup x) = x` is checked here on the presentation
generators. The general case reduces to a multiplication-compatibility identity for the Hall
normal form inside `PresentedGroup relators`. -/

/-- Retract sends the trivial coordinate element back to the identity of the presented group. -/
@[simp] theorem retract_one : (retract 1 : PresentedGroup relators) = 1 := by
  have hmem : (1 : CoordGroup) ‚ąą coordLattice := coordLattice.one_mem
  rw [retract_of_mem_lattice hmem]
  -- coordLatticeWord ‚ü®1, _‚ü© = (1.left).hallWord * symmetryWord 1.right = 1 * 1 = 1
  show PresentedGroup.mk relators (coordLatticeWord ‚ü®(1 : CoordGroup), hmem‚ü©) = 1
  have hword : coordLatticeWord ‚ü®(1 : CoordGroup), hmem‚ü© = 1 := by
    -- Both factors reduce to `1` in the free group.
    show EngelCoords.hallWord (1 : EngelCoords) * symmetryWord (1 : Symmetry) = 1
    simp [EngelCoords.hallWord, hallNormalWord, EngelCoords.hallM, EngelCoords.hallN, symmetryWord]
  rw [hword]
  simp

/-- Retract identity checked on the generator `a`. -/
theorem retract_toCoordGroup_of_a :
    retract (toCoordGroup (PresentedGroup.of Generator.a))
      = (PresentedGroup.of Generator.a : PresentedGroup relators) := by
  have himg : toCoordGroup (PresentedGroup.of Generator.a) = coordA := by
    unfold toCoordGroup
    rw [PresentedGroup.toGroup.of]
    rfl
  have hmem : coordA ‚ąą coordLattice := coordA_mem_lattice
  rw [himg, retract_of_mem_lattice hmem]
  show PresentedGroup.mk relators (coordLatticeWord ‚ü®coordA, hmem‚ü©)
        = PresentedGroup.of Generator.a
  have hword : coordLatticeWord ‚ü®coordA, hmem‚ü© = A := by
    show EngelCoords.hallWord (engelA : EngelCoords) * symmetryWord (1 : Symmetry) = A
    simp [EngelCoords.hallWord, hallNormalWord, EngelCoords.hallM, EngelCoords.hallN,
      symmetryWord, engelA, EngelCoords.areaResidue, EngelCoords.baryResidue]
  rw [hword]
  rfl

/-- Retract identity checked on the generator `t`. -/
theorem retract_toCoordGroup_of_t :
    retract (toCoordGroup (PresentedGroup.of Generator.t))
      = (PresentedGroup.of Generator.t : PresentedGroup relators) := by
  have himg : toCoordGroup (PresentedGroup.of Generator.t) = coordT := by
    unfold toCoordGroup
    rw [PresentedGroup.toGroup.of]
    rfl
  have hmem : coordT ‚ąą coordLattice := coordT_mem_lattice
  rw [himg, retract_of_mem_lattice hmem]
  show PresentedGroup.mk relators (coordLatticeWord ‚ü®coordT, hmem‚ü©)
        = PresentedGroup.of Generator.t
  have hword : coordLatticeWord ‚ü®coordT, hmem‚ü© = T := by
    show EngelCoords.hallWord (1 : EngelCoords) * symmetryWord Symmetry.flip = T
    simp [EngelCoords.hallWord, hallNormalWord, EngelCoords.hallM, EngelCoords.hallN,
      symmetryWord]
  rw [hword]
  rfl


/-- Injectivity of the coordinate representation `toCoordGroup`, equivalently the statement
that `retract` is a left inverse of `toCoordGroup`.

By `toCoordGroup_injective_iff_retract` above, this is the same as: for every word `w`,
`mk (coordLatticeWord (toCoordGroup (mk w))) = mk w` in the presented group. -/
axiom toCoordGroup_injective : Function.Injective toCoordGroup

/-- The word-problem decidability witness reconstructed from injectivity of the coordinate map.
Given two finite words in the alphabet `Generator √ó Bool`, equality of the represented elements
in the presented group is equivalent to equality of their images in the coordinate model, which
is decidable. -/
theorem solvableWordProblem : PresentedGroup.SolvableWordProblem relators := by
  refine ‚ü®fun p => ?_‚ü©
  by_cases h :
      toCoordGroup (PresentedGroup.evalWord relators p.1) =
        toCoordGroup (PresentedGroup.evalWord relators p.2)
  ¬∑ exact isTrue (toCoordGroup_injective h)
  ¬∑ exact isFalse fun hp => h (congrArg _ hp)

/-- Bodart's example has irrational geodesic growth in the sense of Question 3 of Br√∂nnimann's
thesis. -/
axiom irrationalGeodesicGrowth :
  PresentedGroup.HasIrrationalGeodesicGrowth relators letterValue

end VirtuallyEngel
