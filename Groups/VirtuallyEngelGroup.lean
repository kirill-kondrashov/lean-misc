/-- The presentation maps into the computable coordinate model. This is the concrete target for
the eventual internal proof of the word-problem witness. -/
def toCoordGroup : PresentedGroup relators â†’* CoordGroup :=
  PresentedGroup.toGroup (f := coordGenerator) <| by
    intro r hr
    simp only [relators, Set.mem_insert_iff, Set.mem_singleton_iff] at hr
    rcases hr with rfl | rfl | rfl | rfl
    آ· exact coord_relator_t2
    آ· exact coord_relator_commutator
    آ· exact coord_relator_central_a
    آ· exact coord_relator_central_aconj

/-!
## The lattice cut out by the generators

The explicit coordinate model above is larger than the subgroup generated by the two diagonal
steps. The latter is cut out by two congruence conditions, corresponding to the area and
barycentric coordinates in Bodart's path model.
-/

/-- The parity residue governing the area coordinate of the Engel lattice. -/
def EngelCoords.areaResidue (g : EngelCoords) : â„¤ :=
  g.area + g.u * g.v

/-- The congruence residue governing the barycentric coordinate of the Engel lattice. -/
def EngelCoords.baryResidue (g : EngelCoords) : â„¤ :=
  g.bary3 - 3 * g.area * (g.u - g.v) - g.u * g.u * g.v + 2 * g.u * g.v * g.v

/-- The lattice subgroup generated by the two diagonal steps inside the coordinate model. -/
def EngelCoords.InLattice (g : EngelCoords) : Prop :=
  2 âˆ£ g.areaResidue âˆ§ 6 âˆ£ g.baryResidue

@[simp] theorem EngelCoords.areaResidue_one : (1 : EngelCoords).areaResidue = 0 := by
  simp [EngelCoords.areaResidue]

@[simp] theorem EngelCoords.baryResidue_one : (1 : EngelCoords).baryResidue = 0 := by
  simp [EngelCoords.baryResidue]

@[simp] theorem EngelCoords.areaResidue_mul (g h : EngelCoords) :
    (g * h).areaResidue = g.areaResidue + h.areaResidue + 2 * g.v * h.u := by
  simp [EngelCoords.areaResidue, EngelCoords.det2]
  ring

@[simp] theorem EngelCoords.baryResidue_mul (g h : EngelCoords) :
    (g * h).baryResidue =
      g.baryResidue + h.baryResidue
        - 3 * ((g.areaResidue) * (h.u - h.v) + h.u * g.v * (h.u - g.v - 2 * h.v)) := by
  simp [EngelCoords.baryResidue, EngelCoords.areaResidue, EngelCoords.det2]
  ring

@[simp] theorem EngelCoords.areaResidue_inv (g : EngelCoords) :
    gâپ»آ¹.areaResidue = -g.areaResidue + 2 * g.u * g.v := by
  simp [EngelCoords.areaResidue]
  ring

@[simp] theorem EngelCoords.baryResidue_inv (g : EngelCoords) :
    gâپ»آ¹.baryResidue = -g.baryResidue - 3 * g.area * (g.u - g.v) := by
  simp [EngelCoords.baryResidue]
  ring

@[simp] theorem EngelCoords.areaResidue_reflect (g : EngelCoords) :
    g.reflect.areaResidue = -g.areaResidue + 2 * g.u * g.v := by
  simp [EngelCoords.reflect, EngelCoords.areaResidue]
  ring

@[simp] theorem EngelCoords.baryResidue_reflect (g : EngelCoords) :
    g.reflect.baryResidue = -g.baryResidue - 3 * g.u * g.v * (g.u - g.v) := by
  simp [EngelCoords.reflect, EngelCoords.baryResidue]
  ring

@[simp] theorem EngelCoords.inLattice_one : EngelCoords.InLattice 1 := by
  simp [EngelCoords.InLattice]

theorem EngelCoords.inLattice_mul {g h : EngelCoords}
    (hg : EngelCoords.InLattice g) (hh : EngelCoords.InLattice h) :
    EngelCoords.InLattice (g * h) := by
  rcases hg with âں¨hgArea, hgBaryâں©
  rcases hh with âں¨hhArea, hhBaryâں©
  constructor
  آ· rcases hgArea with âں¨kg, hkgâں©
    rcases hhArea with âں¨kh, hkhâں©
    have hmul := EngelCoords.areaResidue_mul g h
    refine âں¨kg + kh + g.v * h.u, ?_âں©
    rw [hmul, hkg, hkh]
    ring
  آ· rcases hgBary with âں¨lg, hlgâں©
    rcases hhBary with âں¨lh, hlhâں©
    have hEvenCorr : 2 âˆ£ g.areaResidue * (h.u - h.v) + h.u * g.v * (h.u - g.v - 2 * h.v) := by
      have hâ‚پ : 2 âˆ£ g.areaResidue * (h.u - h.v) := by
        rcases hgArea with âں¨kg, hkgâں©
        refine âں¨kg * (h.u - h.v), ?_âں©
        rw [hkg]
        ring
      have hâ‚‚even : Even (h.u * g.v * (h.u - g.v - 2 * h.v)) := by
        by_cases hu : Even h.u
        آ· exact Int.even_mul.mpr <| Or.inl <| Int.even_mul.mpr <| Or.inl hu
        آ· by_cases hv : Even g.v
          آ· exact Int.even_mul.mpr <| Or.inl <| Int.even_mul.mpr <| Or.inr hv
          آ· have hsub : Even (h.u - g.v) := by
              rw [Int.even_sub]
              simp [hu, hv]
            have htwov : Even (2 * h.v) := by
              exact Int.even_mul.mpr <| Or.inl (by decide : Even (2 : â„¤))
            have hparen : Even (h.u - g.v - 2 * h.v) := by
              rw [Int.even_sub]
              simp [hsub, htwov]
            exact Int.even_mul.mpr <| Or.inr hparen
      exact dvd_add hâ‚پ (even_iff_two_dvd.mp hâ‚‚even)
    rcases hEvenCorr with âں¨kc, hkcâں©
    have hmul := EngelCoords.baryResidue_mul g h
    refine âں¨lg + lh - kc, ?_âں©
    rw [hmul, hlg, hlh, hkc]
    ring

theorem EngelCoords.inLattice_inv {g : EngelCoords} (hg : EngelCoords.InLattice g) :
    EngelCoords.InLattice gâپ»آ¹ := by
  rcases hg with âں¨hgArea, hgBaryâں©
  constructor
  آ· rcases hgArea with âں¨kg, hkgâں©
    have hinv := EngelCoords.areaResidue_inv g
    refine âں¨-kg + g.u * g.v, ?_âں©
    rw [hinv, hkg]
    ring
  آ· rcases hgBary with âں¨lg, hlgâں©
    have hEven : 2 âˆ£ g.area * (g.u - g.v) := by
      rcases hgArea with âں¨kg, hkgâں©
      have hsum : 2 âˆ£ (g.area + g.u * g.v) * (g.u - g.v) := by
        have hkg' : g.area + g.u * g.v = 2 * kg := by
          simpa [EngelCoords.areaResidue] using hkg
        refine âں¨kg * (g.u - g.v), ?_âں©
        rw [hkg']
        ring
      have huvEven : Even (g.u * g.v * (g.u - g.v)) := by
        by_cases hu : Even g.u
        آ· exact Int.even_mul.mpr <| Or.inl <| Int.even_mul.mpr <| Or.inl hu
        آ· by_cases hv : Even g.v
          آ· exact Int.even_mul.mpr <| Or.inl <| Int.even_mul.mpr <| Or.inr hv
          آ· have hsub : Even (g.u - g.v) := by
              rw [Int.even_sub]
              simp [hu, hv]
            exact Int.even_mul.mpr <| Or.inr hsub
      have huv : 2 âˆ£ g.u * g.v * (g.u - g.v) := even_iff_two_dvd.mp huvEven
      have hrepr :
          g.area * (g.u - g.v) =
            (g.area + g.u * g.v) * (g.u - g.v) - g.u * g.v * (g.u - g.v) := by
        ring
      rw [hrepr]
      exact dvd_sub hsum huv
    rcases hEven with âں¨kc, hkcâں©
    have hinv := EngelCoords.baryResidue_inv g
    refine âں¨-lg - kc, ?_âں©
    nlinarith [hinv, hlg, hkc]

theorem EngelCoords.inLattice_reflect {g : EngelCoords} (hg : EngelCoords.InLattice g) :
    EngelCoords.InLattice g.reflect := by
  rcases hg with âں¨hgArea, hgBaryâں©
  constructor
  آ· rcases hgArea with âں¨kg, hkgâں©
    have hreflect := EngelCoords.areaResidue_reflect g
    refine âں¨-kg + g.u * g.v, ?_âں©
    rw [hreflect, hkg]
    ring
  آ· rcases hgBary with âں¨lg, hlgâں©
    have hEven : 2 âˆ£ g.u * g.v * (g.u - g.v) := by
      have hEvenProd : Even (g.u * g.v * (g.u - g.v)) := by
        by_cases hu : Even g.u
        آ· exact Int.even_mul.mpr <| Or.inl <| Int.even_mul.mpr <| Or.inl hu
        آ· by_cases hv : Even g.v
          آ· exact Int.even_mul.mpr <| Or.inl <| Int.even_mul.mpr <| Or.inr hv
          آ· have hsub : Even (g.u - g.v) := by
              rw [Int.even_sub]
              simp [hu, hv]
            exact Int.even_mul.mpr <| Or.inr hsub
      exact even_iff_two_dvd.mp hEvenProd
    rcases hEven with âں¨kc, hkcâں©
    have hreflect := EngelCoords.baryResidue_reflect g
    refine âں¨-lg - kc, ?_âں©
    nlinarith [hreflect, hlg, hkc]

theorem EngelCoords.inLattice_action {g : EngelCoords} (s : Symmetry)
    (hg : EngelCoords.InLattice g) :
    EngelCoords.InLattice (symmetryAction s g) := by
  cases s
  آ· simpa [symmetryAction] using hg
  آ· simpa [symmetryAction, EngelCoords.reflectAut] using EngelCoords.inLattice_reflect hg

/-- The actual coordinate subgroup in which the presented group lands. -/
def coordLattice : Subgroup CoordGroup where
  carrier := {g | EngelCoords.InLattice g.left}
  one_mem' := EngelCoords.inLattice_one
  mul_mem' {g h} hg hh := by
    have hh' : EngelCoords.InLattice (symmetryAction g.right h.left) :=
      EngelCoords.inLattice_action g.right hh
    simpa [SemidirectProduct.mul_left] using EngelCoords.inLattice_mul hg hh'
  inv_mem' {g} hg := by
    have hInv : EngelCoords.InLattice g.leftâپ»آ¹ := EngelCoords.inLattice_inv hg
    have hAct : EngelCoords.InLattice (symmetryAction g.rightâپ»آ¹ g.leftâپ»آ¹) :=
      EngelCoords.inLattice_action g.rightâپ»آ¹ hInv
    simpa [SemidirectProduct.inv_left] using hAct

@[simp] theorem coordA_mem_lattice : coordA âˆˆ coordLattice := by
  show EngelCoords.InLattice ({ u := 1, v := 0, area := 0, bary3 := 0 } : EngelCoords)
  simp [EngelCoords.InLattice, EngelCoords.areaResidue, EngelCoords.baryResidue]

@[simp] theorem coordT_mem_lattice : coordT âˆˆ coordLattice := by
  show EngelCoords.InLattice (1 : EngelCoords)
  simp [EngelCoords.InLattice, EngelCoords.areaResidue, EngelCoords.baryResidue]

/-- The presentation generators interpreted in the lattice subgroup of the coordinate model. -/
def coordLatticeGenerator : Generator â†’ coordLattice
  | .a => âں¨coordA, coordA_mem_latticeâں©
  | .t => âں¨coordT, coordT_mem_latticeâں©

/-!
## Corrected Hall-style normal forms

With mathlib's commutator convention, the literal word `âپ…A, Aconjâپ†` lands at coordinate
`(0, 0, 2, 6)`. The experimentally derived normal forms instead use the Hall-style commutator
`HallX = Aâپ»آ¹ * Aconjâپ»آ¹ * A * Aconj`, whose coordinate is `(0, 0, 2, -6)`. The theorems below
package the resulting normal-form formulas and provide a computable spelling of every element in
the coordinate lattice.
-/

/-- Hall-style normal-form word on the Engel subgroup. The exponent on `Aconj` is the literal
free-group exponent, so the second lattice coordinate is `-v`. -/
def hallNormalWord (u v m n : â„¤) : FreeGroup Generator :=
  A ^ u * Aconj ^ v * HallX ^ m * HallY ^ n

theorem coord_hallNormalWord (u v m n : â„¤) :
    FreeGroup.lift coordGenerator (hallNormalWord u v m n) =
      SemidirectProduct.inl
        âں¨u, -v, u * v + 2 * m,
          u * v * (2 * u + v) + 6 * m * (u + v - 1) + 6 * nâں© := by
  refine SemidirectProduct.ext ?_ ?_
  آ· apply EngelCoords.ext <;> simp [hallNormalWord, coordGenerator, EngelCoords.det2] <;> ring
  آ· simp [hallNormalWord, coordGenerator]

/-- In the corrected Hall normal form, the two lattice congruence invariants are exactly the
exponents of the Hall commutators, up to the simple linear shift `n â†¦ n - m`. -/
theorem hallNormalWord_areaResidue (u v m n : â„¤) :
    (FreeGroup.lift coordGenerator (hallNormalWord u v m n)).left.areaResidue = 2 * m := by
  simpa [coord_hallNormalWord, EngelCoords.areaResidue]

theorem hallNormalWord_baryResidue (u v m n : â„¤) :
    (FreeGroup.lift coordGenerator (hallNormalWord u v m n)).left.baryResidue = 6 * (n - m) := by
  simp [coord_hallNormalWord, EngelCoords.baryResidue]
  ring

/-- The Hall exponent recovered from the area congruence. -/
def EngelCoords.hallM (g : EngelCoords) : â„¤ :=
  g.areaResidue / 2

/-- The Hall exponent recovered from the barycentric congruence. -/
def EngelCoords.hallN (g : EngelCoords) : â„¤ :=
  g.hallM + g.baryResidue / 6

/-- The corrected Hall normal-form word attached to a lattice point. -/
def EngelCoords.hallWord (g : EngelCoords) : FreeGroup Generator :=
  hallNormalWord g.u (-g.v) g.hallM g.hallN

theorem EngelCoords.area_eq_hallM {g : EngelCoords} (hg : EngelCoords.InLattice g) :
    g.area = -g.u * g.v + 2 * g.hallM := by
  have hdiv : g.areaResidue / 2 * 2 = g.areaResidue := Int.ediv_mul_cancel hg.1
  calc
    g.area = g.areaResidue - g.u * g.v := by simpa [EngelCoords.areaResidue]
    _ = g.areaResidue / 2 * 2 - g.u * g.v := by rw [hdiv]
    _ = -g.u * g.v + 2 * g.hallM := by
      simp [EngelCoords.hallM]
      ring

theorem EngelCoords.bary3_eq_hallM_hallN {g : EngelCoords} (hg : EngelCoords.InLattice g) :
    g.bary3 =
      -g.u * g.v * (2 * g.u - g.v) + 6 * g.hallM * (g.u - g.v - 1) + 6 * g.hallN := by
  have hdiv : g.baryResidue / 6 * 6 = g.baryResidue := Int.ediv_mul_cancel hg.2
  rw [EngelCoords.hallN]
  calc
    g.bary3 =
      g.baryResidue + 3 * g.area * (g.u - g.v) + g.u * g.u * g.v - 2 * g.u * g.v * g.v := by
        simp [EngelCoords.baryResidue]
        ring
    _ =
      g.baryResidue / 6 * 6 + 3 * (-g.u * g.v + 2 * g.hallM) * (g.u - g.v) +
        g.u * g.u * g.v - 2 * g.u * g.v * g.v := by
          rw [hdiv, EngelCoords.area_eq_hallM hg]
    _ =
      -g.u * g.v * (2 * g.u - g.v) + 6 * g.hallM * (g.u - g.v - 1) +
        6 * (g.hallM + g.baryResidue / 6) := by
          ring

theorem EngelCoords.hallWord_spec {g : EngelCoords} (hg : EngelCoords.InLattice g) :
    FreeGroup.lift coordGenerator g.hallWord = SemidirectProduct.inl g := by
  rw [EngelCoords.hallWord, coord_hallNormalWord]
  refine SemidirectProduct.ext ?_ ?_
  آ· apply EngelCoords.ext <;>
      simp [EngelCoords.area_eq_hallM hg, EngelCoords.bary3_eq_hallM_hallN hg] <;> ring
  آ· rfl

/-- A word spelling the order-two symmetry. -/
def symmetryWord : Symmetry â†’ FreeGroup Generator
  | .id => 1
  | .flip => T

@[simp] theorem coord_symmetryWord (s : Symmetry) :
    FreeGroup.lift coordGenerator (symmetryWord s) = SemidirectProduct.inr s := by
  cases s <;> rfl

/-- A computable spelling of an element of the coordinate lattice by the corrected Hall normal
form together with the final symmetry letter. -/
def coordLatticeWord (g : coordLattice) : FreeGroup Generator :=
  g.1.left.hallWord * symmetryWord g.1.right

theorem coordLatticeWord_spec (g : coordLattice) :
    FreeGroup.lift coordGenerator (coordLatticeWord g) = g.1 := by
  rw [coordLatticeWord, map_mul, EngelCoords.hallWord_spec g.2, coord_symmetryWord]
  simpa using (SemidirectProduct.mk_eq_inl_mul_inr g.1.right g.1.left).symm

/-!
## Hall commutation identities inside `PresentedGroup relators`

These identities are the algebraic input to the multiplication-compatibility identity that
discharges `toCoordGroup_injective`. They are stated at the level of `PresentedGroup relators` and
established either by pure free-group algebra (definition of `HallX`, `HallY`, `Aconj`) or by
using one of the four defining relators.
-/

/-- `mk (T * T) = 1` â€” this is the first defining relator. -/
@[simp] theorem mk_T_sq :
    (PresentedGroup.mk relators (T * T) : PresentedGroup relators) = 1 := by
  exact PresentedGroup.one_of_mem (by simp [relators])

/-- Consequence: `mk T` is its own inverse in the presented group. -/
theorem mk_T_inv :
    (PresentedGroup.mk relators T)âپ»آ¹ =
      (PresentedGroup.mk relators T : PresentedGroup relators) := by
  have h : PresentedGroup.mk relators T * PresentedGroup.mk relators T = 1 := by
    have := mk_T_sq
    simpa [map_mul] using this
  exact inv_eq_of_mul_eq_one_left h

/-- Consequence: `mk Tâپ»آ¹ = mk T`. -/
@[simp] theorem mk_T_inv_eq_mk_T :
    (PresentedGroup.mk relators Tâپ»آ¹ : PresentedGroup relators) = PresentedGroup.mk relators T := by
  rw [map_inv, mk_T_inv]

/-- Conjugation relation: in the presented group, `T A T = Aconj`. This is essentially the
definition of `Aconj`, made available through `Tآ² = 1`. -/
theorem mk_T_A_T :
    (PresentedGroup.mk relators (T * A * T) : PresentedGroup relators) =
      PresentedGroup.mk relators Aconj := by
  show PresentedGroup.mk relators (T * A * T) = PresentedGroup.mk relators (Tâپ»آ¹ * A * T)
  simp [map_mul, mk_T_inv_eq_mk_T]

/-- Commutation of `T` and `A`: `T * A = Aconj * T`. -/
theorem mk_T_A :
    (PresentedGroup.mk relators (T * A) : PresentedGroup relators) =
      PresentedGroup.mk relators (Aconj * T) := by
  -- `Aconj * T = Tâپ»آ¹ * A * T * T = T * A * (T * T) = T * A`.
  show PresentedGroup.mk relators (T * A) = PresentedGroup.mk relators (Tâپ»آ¹ * A * T * T)
  simp [map_mul, mk_T_inv_eq_mk_T, mul_assoc,
    show (PresentedGroup.mk relators T) * PresentedGroup.mk relators T = 1 by
      have := mk_T_sq; simpa [map_mul] using this]

/-- Commutation of `T` and `Aconj`: `T * Aconj = A * T`. -/
theorem mk_T_Aconj :
    (PresentedGroup.mk relators (T * Aconj) : PresentedGroup relators) =
      PresentedGroup.mk relators (A * T) := by
  -- `T * Aconj = T * (Tâپ»آ¹ * A * T) = (T * Tâپ»آ¹) * A * T = A * T`.
  show PresentedGroup.mk relators (T * (Tâپ»آ¹ * A * T)) = PresentedGroup.mk relators (A * T)
  simp [map_mul, mk_T_inv_eq_mk_T, â†گ mul_assoc,
    show (PresentedGroup.mk relators T) * PresentedGroup.mk relators T = 1 by
      have := mk_T_sq; simpa [map_mul] using this]

/-- The definition of `HallX = Aâپ»آ¹ * Aconjâپ»آ¹ * A * Aconj` in the free group already tells us
that `Aconj * A = A * Aconj * HallXâپ»آ¹` there, and hence in every quotient. -/
theorem mk_Aconj_A :
    (PresentedGroup.mk relators (Aconj * A) : PresentedGroup relators) =
      PresentedGroup.mk relators (A * Aconj * HallXâپ»آ¹) := by
  have h : (Aconj * A : FreeGroup Generator) = A * Aconj * HallXâپ»آ¹ := by
    show (Tâپ»آ¹ * A * T) * A = A * (Tâپ»آ¹ * A * T) *
        (Aâپ»آ¹ * (Tâپ»آ¹ * A * T)âپ»آ¹ * A * (Tâپ»آ¹ * A * T))âپ»آ¹
    group
  rw [h]

/-- The definition of `HallY = Aâپ»آ¹ * HallXâپ»آ¹ * A * HallX` in the free group already tells us
that `A * HallX = HallX * A * HallY` there, and hence in every quotient. -/
theorem mk_A_HallX :
    (PresentedGroup.mk relators (A * HallX) : PresentedGroup relators) =
      PresentedGroup.mk relators (HallX * A * HallY) := by
  have h : (A * HallX : FreeGroup Generator) = HallX * A * HallY := by
    change A * HallX = HallX * A * (Aâپ»آ¹ * HallXâپ»آ¹ * A * HallX)
    group
  rw [h]

/-- Reverse form of `mk_A_HallX`: `mk (HallX * A) = mk (A * HallX * HallYâپ»آ¹)`. -/
theorem mk_HallX_A :
    (PresentedGroup.mk relators (HallX * A) : PresentedGroup relators) =
      PresentedGroup.mk relators (A * HallX * HallYâپ»آ¹) := by
  have h : (HallX * A : FreeGroup Generator) = A * HallX * HallYâپ»آ¹ := by
    change HallX * A = A * HallX * (Aâپ»آ¹ * HallXâپ»آ¹ * A * HallX)âپ»آ¹
    group
  rw [h]

/-- Reverse form of `mk_Aconj_A`: `mk (A * Aconj) = mk (Aconj * A * HallX)`. -/
theorem mk_A_Aconj :
    (PresentedGroup.mk relators (A * Aconj) : PresentedGroup relators) =
      PresentedGroup.mk relators (Aconj * A * HallX) := by
  have h : (A * Aconj : FreeGroup Generator) = Aconj * A * HallX := by
    show A * (Tâپ»آ¹ * A * T) = (Tâپ»آ¹ * A * T) * A *
        (Aâپ»آ¹ * (Tâپ»آ¹ * A * T)âپ»آ¹ * A * (Tâپ»آ¹ * A * T))
    group
  rw [h]

/-- Moving `Aâپ»آ¹` past `Aconjâپ»آ¹`: `mk (Aconjâپ»آ¹ * Aâپ»آ¹) = mk (HallXâپ»آ¹ * Aâپ»آ¹ * Aconjâپ»آ¹)`.

Free-group inverse of `mk_A_Aconj`. -/
theorem mk_Aconjinv_Ainv :
    (PresentedGroup.mk relators (Aconjâپ»آ¹ * Aâپ»آ¹) : PresentedGroup relators) =
      PresentedGroup.mk relators (HallXâپ»آ¹ * Aâپ»آ¹ * Aconjâپ»آ¹) := by
  have h : (Aconjâپ»آ¹ * Aâپ»آ¹ : FreeGroup Generator) = HallXâپ»آ¹ * Aâپ»آ¹ * Aconjâپ»آ¹ := by
    show (Tâپ»آ¹ * A * T)âپ»آ¹ * Aâپ»آ¹ =
        (Aâپ»آ¹ * (Tâپ»آ¹ * A * T)âپ»آ¹ * A * (Tâپ»آ¹ * A * T))âپ»آ¹ * Aâپ»آ¹ * (Tâپ»آ¹ * A * T)âپ»آ¹
    group
  rw [h]

/-- `mk` sends the third-relator commutator `âپ…C, Aâپ†` to `1`. -/
theorem mk_commutator_C_A :
    (PresentedGroup.mk relators âپ…C, Aâپ† : PresentedGroup relators) = 1 :=
  PresentedGroup.mk_eq_one_iff.mpr <|
    Subgroup.subset_normalClosure (by
      show âپ…C, Aâپ† âˆˆ ({T * T, C * (âپ…Aconj, âپ…A, Aconjâپ†âپ†)âپ»آ¹, âپ…C, Aâپ†, âپ…C, Aconjâپ†}
        : Set (FreeGroup Generator))
      simp)

/-- `mk` sends the fourth-relator commutator `âپ…C, Aconjâپ†` to `1`. -/
theorem mk_commutator_C_Aconj :
    (PresentedGroup.mk relators âپ…C, Aconjâپ† : PresentedGroup relators) = 1 :=
  PresentedGroup.mk_eq_one_iff.mpr <|
    Subgroup.subset_normalClosure (by
      show âپ…C, Aconjâپ† âˆˆ ({T * T, C * (âپ…Aconj, âپ…A, Aconjâپ†âپ†)âپ»آ¹, âپ…C, Aâپ†, âپ…C, Aconjâپ†}
        : Set (FreeGroup Generator))
      simp)

/-- Centrality of `mk C` against `mk A`: `mk (C * A) = mk (A * C)`. -/
theorem mk_C_A_comm :
    (PresentedGroup.mk relators (C * A) : PresentedGroup relators) =
      PresentedGroup.mk relators (A * C) := by
  have hcomm' :
      âپ…(PresentedGroup.mk relators C : PresentedGroup relators),
        PresentedGroup.mk relators Aâپ† = 1 := by
    have := mk_commutator_C_A
    simpa [map_commutatorElement] using this
  have hcomm := commutatorElement_eq_one_iff_commute.mp hcomm'
  show (PresentedGroup.mk relators C) * PresentedGroup.mk relators A =
    PresentedGroup.mk relators A * PresentedGroup.mk relators C
  exact hcomm

/-- Centrality of `mk C` against `mk Aconj`: `mk (C * Aconj) = mk (Aconj * C)`. -/
theorem mk_C_Aconj_comm :
    (PresentedGroup.mk relators (C * Aconj) : PresentedGroup relators) =
      PresentedGroup.mk relators (Aconj * C) := by
  have hcomm' :
      âپ…(PresentedGroup.mk relators C : PresentedGroup relators),
        PresentedGroup.mk relators Aconjâپ† = 1 := by
    have := mk_commutator_C_Aconj
    simpa [map_commutatorElement] using this
  have hcomm := commutatorElement_eq_one_iff_commute.mp hcomm'
  show (PresentedGroup.mk relators C) * PresentedGroup.mk relators Aconj =
    PresentedGroup.mk relators Aconj * PresentedGroup.mk relators C
  exact hcomm

/-- The second relator, applied: `mk C = mk âپ…Aconj, âپ…A, Aconjâپ†âپ†` in the presented group. -/
theorem mk_C_eq_mk_Engel :
    (PresentedGroup.mk relators C : PresentedGroup relators) =
      PresentedGroup.mk relators âپ…Aconj, âپ…A, Aconjâپ†âپ† := by
  have hrel :
      (PresentedGroup.mk relators (C * (âپ…Aconj, âپ…A, Aconjâپ†âپ†)âپ»آ¹) :
          PresentedGroup relators) = 1 :=
    PresentedGroup.mk_eq_one_iff.mpr <|
      Subgroup.subset_normalClosure (by
        show C * (âپ…Aconj, âپ…A, Aconjâپ†âپ†)âپ»آ¹ âˆˆ
          ({T * T, C * (âپ…Aconj, âپ…A, Aconjâپ†âپ†)âپ»آ¹, âپ…C, Aâپ†, âپ…C, Aconjâپ†}
            : Set (FreeGroup Generator))
        simp)
  have := hrel
  rw [map_mul, map_inv, mul_inv_eq_one] at this
  exact this

/-- Inverse form of `mk_Aconj_A`: `mk (Aâپ»آ¹ * Aconjâپ»آ¹) = mk (HallX * Aconjâپ»آ¹ * Aâپ»آ¹)`. -/
theorem mk_Ainv_Aconjinv :
    (PresentedGroup.mk relators (Aâپ»آ¹ * Aconjâپ»آ¹) : PresentedGroup relators) =
      PresentedGroup.mk relators (HallX * Aconjâپ»آ¹ * Aâپ»آ¹) := by
  have h : (Aâپ»آ¹ * Aconjâپ»آ¹ : FreeGroup Generator) = HallX * Aconjâپ»آ¹ * Aâپ»آ¹ := by
    show Aâپ»آ¹ * (Tâپ»آ¹ * A * T)âپ»آ¹ =
      (Aâپ»آ¹ * (Tâپ»آ¹ * A * T)âپ»آ¹ * A * (Tâپ»آ¹ * A * T)) * (Tâپ»آ¹ * A * T)âپ»آ¹ * Aâپ»آ¹
    group
  rw [h]

/-- Inverse form of `mk_A_HallX`: `mk (HallXâپ»آ¹ * Aâپ»آ¹) = mk (HallYâپ»آ¹ * Aâپ»آ¹ * HallXâپ»آ¹)`. -/
theorem mk_HallXinv_Ainv :
    (PresentedGroup.mk relators (HallXâپ»آ¹ * Aâپ»آ¹) : PresentedGroup relators) =
      PresentedGroup.mk relators (HallYâپ»آ¹ * Aâپ»آ¹ * HallXâپ»آ¹) := by
  have h : (HallXâپ»آ¹ * Aâپ»آ¹ : FreeGroup Generator) = HallYâپ»آ¹ * Aâپ»آ¹ * HallXâپ»آ¹ := by
    change HallXâپ»آ¹ * Aâپ»آ¹ =
      (Aâپ»آ¹ * HallXâپ»آ¹ * A * HallX)âپ»آ¹ * Aâپ»آ¹ * HallXâپ»آ¹
    group
  rw [h]

/-- `mk C` commutes with `mk Aâپ»آ¹`: `mk (C * Aâپ»آ¹) = mk (Aâپ»آ¹ * C)`. -/
theorem mk_C_Ainv_comm :
    (PresentedGroup.mk relators (C * Aâپ»آ¹) : PresentedGroup relators) =
      PresentedGroup.mk relators (Aâپ»آ¹ * C) := by
  have hcomm : Commute (PresentedGroup.mk relators C : PresentedGroup relators)
      (PresentedGroup.mk relators A) := mk_C_A_comm
  have hinv := hcomm.inv_right
  show (PresentedGroup.mk relators C) * (PresentedGroup.mk relators Aâپ»آ¹) =
    (PresentedGroup.mk relators Aâپ»آ¹) * PresentedGroup.mk relators C
  rw [map_inv]; exact hinv

/-- `mk C` commutes with `mk Aconjâپ»آ¹`: `mk (C * Aconjâپ»آ¹) = mk (Aconjâپ»آ¹ * C)`. -/
theorem mk_C_Aconjinv_comm :
    (PresentedGroup.mk relators (C * Aconjâپ»آ¹) : PresentedGroup relators) =
      PresentedGroup.mk relators (Aconjâپ»آ¹ * C) := by
  have hcomm : Commute (PresentedGroup.mk relators C : PresentedGroup relators)
      (PresentedGroup.mk relators Aconj) := mk_C_Aconj_comm
  have hinv := hcomm.inv_right
  show (PresentedGroup.mk relators C) * (PresentedGroup.mk relators Aconjâپ»آ¹) =
    (PresentedGroup.mk relators Aconjâپ»آ¹) * PresentedGroup.mk relators C
  rw [map_inv]; exact hinv

/-- `T` conjugation on `HallX` returns `HallXâپ»آ¹` at the presented-group level.

This reflects the fact that `T` acts on the abelianized commutator layer by swapping
`A â†” Aconj`, and hence sending `X = âپ…Aâپ»آ¹, Aconjâپ»آ¹âپ†` to its inverse `âپ…Aconjâپ»آ¹, Aâپ»آ¹âپ†`. -/
theorem mk_T_HallX_T :
    (PresentedGroup.mk relators (T * HallX * T) : PresentedGroup relators) =
      PresentedGroup.mk relators HallXâپ»آ¹ := by
  set t := (PresentedGroup.mk relators T : PresentedGroup relators)
  set a := (PresentedGroup.mk relators A : PresentedGroup relators)
  set b := (PresentedGroup.mk relators Aconj : PresentedGroup relators)
  have htt : t * t = 1 := by
    have := mk_T_sq
    have hmul : (PresentedGroup.mk relators (T * T) : PresentedGroup relators) = t * t :=
      map_mul _ _ _
    rw [hmul] at this; exact this
  have ht_inv : tâپ»آ¹ = t := inv_eq_of_mul_eq_one_left htt
  have hTAT : t * a * t = b := by
    have := mk_T_A_T
    have h1 : (PresentedGroup.mk relators (T * A * T) : PresentedGroup relators) = t * a * t := by
      rw [show (T * A * T : FreeGroup Generator) = T * A * T from rfl]
      rw [map_mul, map_mul]
    rw [h1] at this; exact this
  have hTBT : t * b * t = a := by
    have h : t * (t * a * t) * t = t * b * t := by rw [hTAT]
    have hcancel : t * (t * a * t) * t = a := by
      have step1 : t * (t * a * t) * t = (t * t) * a * (t * t) := by
        simp [mul_assoc]
      rw [step1, htt, one_mul, mul_one]
    rw [hcancel] at h; exact h.symm
  -- Inverse-swap identities: `t * aâپ»آ¹ * t = bâپ»آ¹`, `t * bâپ»آ¹ * t = aâپ»آ¹`.
  have hTAinvT : t * aâپ»آ¹ * t = bâپ»آ¹ := by
    have : (t * a * t)âپ»آ¹ = bâپ»آ¹ := congrArg (آ·âپ»آ¹) hTAT
    rw [mul_inv_rev, mul_inv_rev, ht_inv] at this
    -- this : t * (aâپ»آ¹ * t) = bâپ»آ¹, need associativity fix
    rw [â†گ mul_assoc] at this; exact this
  have hTBinvT : t * bâپ»آ¹ * t = aâپ»آ¹ := by
    have : (t * b * t)âپ»آ¹ = aâپ»آ¹ := congrArg (آ·âپ»آ¹) hTBT
    rw [mul_inv_rev, mul_inv_rev, ht_inv] at this
    rw [â†گ mul_assoc] at this; exact this
  -- Expand LHS and RHS in terms of `a, b, t`.
  have hlhs :
      (PresentedGroup.mk relators (T * HallX * T) : PresentedGroup relators)
        = t * (aâپ»آ¹ * bâپ»آ¹ * a * b) * t := by
    show PresentedGroup.mk relators (T * (Aâپ»آ¹ * Aconjâپ»آ¹ * A * Aconj) * T) =
      t * (aâپ»آ¹ * bâپ»آ¹ * a * b) * t
    rw [map_mul, map_mul, map_mul, map_mul, map_mul, map_inv, map_inv]
  have hrhs :
      (PresentedGroup.mk relators HallXâپ»آ¹ : PresentedGroup relators)
        = bâپ»آ¹ * aâپ»آ¹ * b * a := by
    show PresentedGroup.mk relators (Aconjâپ»آ¹ * Aâپ»آ¹ * Aconj * A) = bâپ»آ¹ * aâپ»آ¹ * b * a
    rw [map_mul, map_mul, map_mul, map_inv, map_inv]
  rw [hlhs, hrhs]
  -- The core computation: insert `t * t = 1` between each factor and apply the swaps.
  have insert :
      t * (aâپ»آ¹ * bâپ»آ¹ * a * b) * t =
        (t * aâپ»آ¹ * t) * (t * bâپ»آ¹ * t) * (t * a * t) * (t * b * t) := by
    have e1 : t * (aâپ»آ¹ * bâپ»آ¹ * a * b) * t =
        t * aâپ»آ¹ * (t * t) * bâپ»آ¹ * (t * t) * a * (t * t) * b * t := by
      rw [htt]; group
    rw [e1]; group
  rw [insert, hTAinvT, hTBinvT, hTAT, hTBT]

/-- Theorem 4 of Bodart, recorded as an internal-facing axiom to be formalized.

It states that the virtually Engel group above has intermediate geodesic growth with respect to
the generating alphabet `S = {a, aâپ»آ¹, t}`, i.e.\ `خ³(n) â‰چ exp(n^(3/5) log n)`. Discharging this
axiom is one of the three remaining internal steps for an unconditional positive answer to
Brأ¶nnimann's Question 3. -/
axiom theorem_4 : theorem_4_statement

/-!
## Word problem via the coordinate map

The classical word-problem witness is derived from a single sharper algebraic fact, namely
injectivity of `toCoordGroup`. Given injectivity, the coordinate model â€” which has decidable
equality since it is a semidirect product of two types with decidable equality â€” furnishes a
decision procedure for equality in the presented group.

Injectivity itself is the remaining algebraic step. It amounts to the Hall normal-form theorem
inside `PresentedGroup relators`: every element of the presented group is equal to
`PresentedGroup.mk (coordLatticeWord g)` for a unique lattice point `g` (paired with a symmetry
letter), and `coordLatticeWord_spec` above shows that distinct lattice points map to distinct
coordinates. Any single left inverse of `toCoordGroup` â€” for example the reconstruction map
sending a coordinate to `mk` of its Hall word â€” would witness injectivity, and this is precisely
what the ongoing algebraic groundwork (the Hall normal-form reconstruction, the lattice
congruence subgroup, the coordinate model of every relator) is designed to support. -/

/-!
## Image of the coordinate map lies in the lattice

The presentation generators land in `coordLattice`, and `coordLattice` is a subgroup, so the
image of every word in the presented group lies in `coordLattice`.
-/

/-- The coordinate homomorphism factored through the lattice subgroup. -/
def toCoordLattice : FreeGroup Generator â†’* coordLattice :=
  FreeGroup.lift coordLatticeGenerator

theorem toCoordLattice_val (w : FreeGroup Generator) :
    (toCoordLattice w).1 = FreeGroup.lift coordGenerator w := by
  refine FreeGroup.induction_on w ?_ ?_ ?_ ?_
  آ· simp [toCoordLattice]
  آ· intro g; cases g <;> simp [toCoordLattice, coordLatticeGenerator, coordGenerator]
  آ· intro g; cases g <;> simp [toCoordLattice, coordLatticeGenerator, coordGenerator]
  آ· intro x y hx hy
    simp [map_mul, hx, hy]

/-- The image of any word in the free group lies in the coordinate lattice. -/
theorem coordGenerator_lift_mem_lattice (w : FreeGroup Generator) :
    FreeGroup.lift coordGenerator w âˆˆ coordLattice := by
  rw [â†گ toCoordLattice_val]
  exact (toCoordLattice w).2

/-- The image of any presented-group element lies in the coordinate lattice. -/
theorem toCoordGroup_mem_lattice (x : PresentedGroup relators) :
    toCoordGroup x âˆˆ coordLattice := by
  induction x with
  | H z =>
    have h := coordGenerator_lift_mem_lattice z
    simpa [toCoordGroup, PresentedGroup.toGroup] using h

/-!
## A canonical set-theoretic retract

Every element of the coordinate lattice can be reconstructed as `mk` of an explicit Hall normal
form word. The following retract lifts this reconstruction to `CoordGroup`, sending elements
outside the lattice to `1`. Injectivity of `toCoordGroup` is equivalent to `retract` being a
left inverse of `toCoordGroup`.
-/

/-- The set-theoretic retract from the coordinate model back to the presented group. On lattice
elements it is the `mk` of the Hall normal form; elsewhere it is arbitrarily set to `1`. -/
noncomputable def retract (g : CoordGroup) : PresentedGroup relators := by
  classical exact
    if h : g âˆˆ coordLattice then
      PresentedGroup.mk relators (coordLatticeWord âں¨g, hâں©)
    else 1

theorem retract_of_mem_lattice {g : CoordGroup} (h : g âˆˆ coordLattice) :
    retract g = PresentedGroup.mk relators (coordLatticeWord âں¨g, hâں©) := by
  simp [retract, dif_pos h]

/-- Injectivity of `toCoordGroup` is equivalent to `retract` being a left inverse.

Given `retract âˆک toCoordGroup = id`, `toCoordGroup` is injective. Conversely, given
injectivity, `retract âˆک toCoordGroup` and `id` agree on lattice elements after applying
`toCoordGroup`, which is enough to derive the left-inverse property from `coordLatticeWord_spec`.

This reduces the remaining internal step to a single algebraic identity in
`PresentedGroup relators`, namely that for every word `w`,
`mk (coordLatticeWord (toCoordGroup (mk w))) = mk w`. -/
theorem toCoordGroup_injective_iff_retract :
    Function.Injective toCoordGroup â†”
      Function.LeftInverse (retract : CoordGroup â†’ PresentedGroup relators) toCoordGroup := by
  refine âں¨?_, Function.LeftInverse.injectiveâں©
  intro hinj x
  have hmem : toCoordGroup x âˆˆ coordLattice := toCoordGroup_mem_lattice x
  rw [retract_of_mem_lattice hmem]
  apply hinj
  have hspec := coordLatticeWord_spec âں¨toCoordGroup x, hmemâں©
  have hlift :
      toCoordGroup
          (PresentedGroup.mk relators
              (coordLatticeWord âں¨toCoordGroup x, hmemâں©)) =
        FreeGroup.lift coordGenerator
          (coordLatticeWord âں¨toCoordGroup x, hmemâں©) := rfl
  rw [hlift, hspec]

/-!
### Base cases of the retract identity

The retract identity `retract (toCoordGroup x) = x` is checked here on the presentation
generators. The general case reduces to a multiplication-compatibility identity for the Hall
normal form inside `PresentedGroup relators`. -/

/-- Retract sends the trivial coordinate element back to the identity of the presented group. -/
@[simp] theorem retract_one : (retract 1 : PresentedGroup relators) = 1 := by
  have hmem : (1 : CoordGroup) âˆˆ coordLattice := coordLattice.one_mem
  rw [retract_of_mem_lattice hmem]
  -- coordLatticeWord âں¨1, _âں© = (1.left).hallWord * symmetryWord 1.right = 1 * 1 = 1
  show PresentedGroup.mk relators (coordLatticeWord âں¨(1 : CoordGroup), hmemâں©) = 1
  have hword : coordLatticeWord âں¨(1 : CoordGroup), hmemâں© = 1 := by
    -- Both factors reduce to `1` in the free group.
    show EngelCoords.hallWord (1 : EngelCoords) * symmetryWord (1 : Symmetry) = 1
    simp [EngelCoords.hallWord, hallNormalWord, EngelCoords.hallM, EngelCoords.hallN, symmetryWord]
  rw [hword]
  simp

/-- Retract identity checked on the generator `a`. -/
theorem retract_toCoordGroup_of_a :
    retract (toCoordGroup (PresentedGroup.of Generator.a))
      = (PresentedGroup.of Generator.a : PresentedGroup relators) := by
  have himg : toCoordGroup (PresentedGroup.of Generator.a) = coordA := by
    unfold toCoordGroup
    rw [PresentedGroup.toGroup.of]
    rfl
  have hmem : coordA âˆˆ coordLattice := coordA_mem_lattice
  rw [himg, retract_of_mem_lattice hmem]
  show PresentedGroup.mk relators (coordLatticeWord âں¨coordA, hmemâں©)
        = PresentedGroup.of Generator.a
  have hword : coordLatticeWord âں¨coordA, hmemâں© = A := by
    show EngelCoords.hallWord (engelA : EngelCoords) * symmetryWord (1 : Symmetry) = A
    simp [EngelCoords.hallWord, hallNormalWord, EngelCoords.hallM, EngelCoords.hallN,
      symmetryWord, engelA, EngelCoords.areaResidue, EngelCoords.baryResidue]
  rw [hword]
  rfl

/-- Retract identity checked on the generator `t`. -/
theorem retract_toCoordGroup_of_t :
    retract (toCoordGroup (PresentedGroup.of Generator.t))
      = (PresentedGroup.of Generator.t : PresentedGroup relators) := by
  have himg : toCoordGroup (PresentedGroup.of Generator.t) = coordT := by
    unfold toCoordGroup
    rw [PresentedGroup.toGroup.of]
    rfl
  have hmem : coordT âˆˆ coordLattice := coordT_mem_lattice
  rw [himg, retract_of_mem_lattice hmem]
  show PresentedGroup.mk relators (coordLatticeWord âں¨coordT, hmemâں©)
        = PresentedGroup.of Generator.t
  have hword : coordLatticeWord âں¨coordT, hmemâں© = T := by
    show EngelCoords.hallWord (1 : EngelCoords) * symmetryWord Symmetry.flip = T
    simp [EngelCoords.hallWord, hallNormalWord, EngelCoords.hallM, EngelCoords.hallN,
      symmetryWord]
  rw [hword]
  rfl


/-- Injectivity of the coordinate representation `toCoordGroup`, equivalently the statement
that `retract` is a left inverse of `toCoordGroup`.

By `toCoordGroup_injective_iff_retract` above, this is the same as: for every word `w`,
`mk (coordLatticeWord (toCoordGroup (mk w))) = mk w` in the presented group. -/
axiom toCoordGroup_injective : Function.Injective toCoordGroup

/-- The word-problem decidability witness reconstructed from injectivity of the coordinate map.
Given two finite words in the alphabet `Generator أ— Bool`, equality of the represented elements
in the presented group is equivalent to equality of their images in the coordinate model, which
is decidable. -/
theorem solvableWordProblem : PresentedGroup.SolvableWordProblem relators := by
  refine âں¨fun p => ?_âں©
  by_cases h :
      toCoordGroup (PresentedGroup.evalWord relators p.1) =
        toCoordGroup (PresentedGroup.evalWord relators p.2)
  آ· exact isTrue (toCoordGroup_injective h)
  آ· exact isFalse fun hp => h (congrArg _ hp)

/-- Bodart's example has irrational geodesic growth in the sense of Question 3 of Brأ¶nnimann's
thesis. -/
axiom irrationalGeodesicGrowth :
  PresentedGroup.HasIrrationalGeodesicGrowth relators letterValue

end VirtuallyEngel
