import Groups.GeodesicGrowth

open Filter

namespace VirtuallyEngel

/-!
# A virtually Engel group

This file records Bodart's virtually `3`-step nilpotent example with intermediate geodesic
growth.
-/

/-- Generators in the two-generator presentation used for Bodart's virtually Engel group. -/
inductive Generator where
  | a
  | t
  deriving DecidableEq, Fintype

noncomputable instance : Primcodable Generator :=
  Primcodable.ofEquiv (Fin 2) (Fintype.equivFin Generator)

/-- The free-group word corresponding to the generator `a`. -/
abbrev A : FreeGroup Generator :=
  FreeGroup.of Generator.a

/-- The free-group word corresponding to the generator `t`. -/
abbrev T : FreeGroup Generator :=
  FreeGroup.of Generator.t

/-- The conjugate `tâپ»آ¹ a t`, written `aلµ—` in the literature. -/
abbrev Aconj : FreeGroup Generator :=
  Tâپ»آ¹ * A * T

/-- Hall's commutator convention is `xâپ»آ¹ * yâپ»آ¹ * x * y`, opposite to mathlib's
`âپ…x, yâپ† = x * y * xâپ»آ¹ * yâپ»آ¹`.

This is the middle generator matching the experimentally derived normal forms in the coordinate
model below. -/
abbrev HallX : FreeGroup Generator :=
  Aâپ»آ¹ * Aconjâپ»آ¹ * A * Aconj

/-- The corresponding Hall-style third-step commutator. In coordinates this agrees with the
presentation commutator `C`. -/
abbrev HallY : FreeGroup Generator :=
  Aâپ»آ¹ * HallXâپ»آ¹ * A * HallX

/-- The common third-step commutator in Bodart's presentation. -/
abbrev C : FreeGroup Generator :=
  âپ…A, âپ…A, Aconjâپ†âپ†

/-- Relators for Bodart's virtually Engel group:
`tآ² = 1`, `C = [aلµ—, [a, aلµ—]]`, and `C` commutes with both `a` and `aلµ—`. -/
abbrev relators : Set (FreeGroup Generator) :=
  {T * T, C * (âپ…Aconj, âپ…A, Aconjâپ†âپ†)âپ»آ¹, âپ…C, Aâپ†, âپ…C, Aconjâپ†}

/-- Bodart's virtually Engel group. -/
abbrev Group : Type :=
  PresentedGroup relators

/-- The geodesic-growth alphabet `S = {a, aâپ»آ¹, t}` used in Bodart's theorem. -/
inductive Letter where
  | a
  | aInv
  | t
  deriving DecidableEq, Fintype

/-- Interpretation of the Bodart alphabet in the presented group. -/
def letterValue : Letter â†’ Group
  | .a => PresentedGroup.mk relators A
  | .aInv => (PresentedGroup.mk relators A)âپ»آ¹
  | .t => PresentedGroup.mk relators T

/-- Geodesic growth with respect to `S = {a, aâپ»آ¹, t}`. -/
noncomputable abbrev geodesicGrowth : â„• â†’ â„• :=
  PresentedGroup.geodesicGrowth relators letterValue

/-- The comparison function appearing in Bodart's asymptotic estimate. -/
noncomputable def modelGrowth (n : â„•) : â„‌ :=
  Real.exp ((n : â„‌).rpow ((3 : â„‌) / 5) * Real.log (n : â„‌))

/-- A literal formalization of `خ³(n) â‰چ exp(n^{3/5} log n)` as an eventual two-sided bound. -/
def theorem_4_statement : Prop :=
  âˆƒ câ‚پ câ‚‚ : â„‌,
    0 < câ‚پ âˆ§
    câ‚پ â‰¤ câ‚‚ âˆ§
    âˆ€ل¶  n : â„• in atTop,
      câ‚پ * modelGrowth n â‰¤ (geodesicGrowth n : â„‌) âˆ§
      (geodesicGrowth n : â„‌) â‰¤ câ‚‚ * modelGrowth n

/-!
## A computable coordinate model

The next step toward an internal proof of the Bodart witness facts is to work with an explicit
computable model of the underlying virtually Engel group. The model below packages the Engel
subgroup by integer coordinates coming from Bodart's path invariants, together with an order-two
symmetry acting by reflection.
-/

/-- Integer coordinates for the Engel subgroup generated by the two diagonal steps
`a = (1, 0, 0, 0)` and `b = (0, 1, 0, 0)`.

The fields are the two diagonal coordinates together with the algebraic area and three times the
`y`-barycenter used in Bodart's path model. -/
structure EngelCoords where
  u : â„¤
  v : â„¤
  area : â„¤
  bary3 : â„¤
  deriving DecidableEq

noncomputable instance : Primcodable EngelCoords :=
  Primcodable.ofEquiv (â„¤ أ— â„¤ أ— â„¤ أ— â„¤)
    { toFun := fun g => (g.u, g.v, g.area, g.bary3)
      invFun := fun p => âں¨p.1, p.2.1, p.2.2.1, p.2.2.2âں©
      left_inv := by
        intro g
        cases g
        rfl
      right_inv := by
        intro p
        cases p
        rfl }

/-- Half of the determinant term appearing in Bodart's concatenation formula, expressed in the
diagonal coordinates. -/
def EngelCoords.det2 (g h : EngelCoords) : â„¤ :=
  g.v * h.u - g.u * h.v

instance : Mul EngelCoords where
  mul g h :=
    { u := g.u + h.u
      v := g.v + h.v
      area := g.area + h.area + EngelCoords.det2 g h
      bary3 := g.bary3 + h.bary3 + 3 * (g.u - g.v) * h.area +
        (2 * (g.u - g.v) + (h.u - h.v)) * EngelCoords.det2 g h }

instance : One EngelCoords where
  one := âں¨0, 0, 0, 0âں©

instance : Inv EngelCoords where
  inv g := âں¨-g.u, -g.v, -g.area, -g.bary3 + 3 * (g.u - g.v) * g.areaâں©

@[simp] theorem EngelCoords.mul_u (g h : EngelCoords) : (g * h).u = g.u + h.u := rfl
@[simp] theorem EngelCoords.mul_v (g h : EngelCoords) : (g * h).v = g.v + h.v := rfl
@[simp] theorem EngelCoords.mul_area (g h : EngelCoords) :
    (g * h).area = g.area + h.area + EngelCoords.det2 g h := rfl
@[simp] theorem EngelCoords.mul_bary3 (g h : EngelCoords) :
    (g * h).bary3 = g.bary3 + h.bary3 + 3 * (g.u - g.v) * h.area +
      (2 * (g.u - g.v) + (h.u - h.v)) * EngelCoords.det2 g h := rfl
@[simp] theorem EngelCoords.one_u : (1 : EngelCoords).u = 0 := rfl
@[simp] theorem EngelCoords.one_v : (1 : EngelCoords).v = 0 := rfl
@[simp] theorem EngelCoords.one_area : (1 : EngelCoords).area = 0 := rfl
@[simp] theorem EngelCoords.one_bary3 : (1 : EngelCoords).bary3 = 0 := rfl
@[simp] theorem EngelCoords.inv_u (g : EngelCoords) : gâپ»آ¹.u = -g.u := rfl
@[simp] theorem EngelCoords.inv_v (g : EngelCoords) : gâپ»آ¹.v = -g.v := rfl
@[simp] theorem EngelCoords.inv_area (g : EngelCoords) : gâپ»آ¹.area = -g.area := rfl
@[simp] theorem EngelCoords.inv_bary3 (g : EngelCoords) :
    gâپ»آ¹.bary3 = -g.bary3 + 3 * (g.u - g.v) * g.area := rfl

@[ext]
theorem EngelCoords.ext
    {g h : EngelCoords}
    (hu : g.u = h.u) (hv : g.v = h.v) (harea : g.area = h.area)
    (hbary3 : g.bary3 = h.bary3) : g = h := by
  cases g
  cases h
  simp_all

instance : _root_.Group EngelCoords where
  mul_assoc g h k := by
    ext <;> simp [EngelCoords.det2] <;> ring
  one_mul g := by
    ext <;> simp [EngelCoords.det2]
  mul_one g := by
    ext <;> simp [EngelCoords.det2]
  inv_mul_cancel g := by
    ext <;> simp [EngelCoords.det2] <;> ring

/-- The coordinate image of the diagonal step `a`. -/
abbrev engelA : EngelCoords :=
  âں¨1, 0, 0, 0âں©

/-- The coordinate image of `aلµ— = tâپ»آ¹ a t`. -/
abbrev engelAconj : EngelCoords :=
  âں¨0, -1, 0, 0âں©

/-- The corrected Hall-style commutator generator. -/
abbrev engelHallX : EngelCoords :=
  âں¨0, 0, 2, -6âں©

/-- The central Hall-style commutator generator. -/
abbrev engelHallY : EngelCoords :=
  âں¨0, 0, 0, 6âں©

@[simp] theorem engelA_pow (n : â„•) : engelA ^ n = âں¨n, 0, 0, 0âں© := by
  induction n with
  | zero => rfl
  | succ n ih =>
      ext <;> simp [engelA, pow_succ, ih, EngelCoords.det2] <;> ring

@[simp] theorem engelAconj_pow (n : â„•) : engelAconj ^ n = âں¨0, -(n : â„¤), 0, 0âں© := by
  induction n with
  | zero => rfl
  | succ n ih =>
      ext <;> simp [engelAconj, pow_succ, ih, EngelCoords.det2] <;> ring

@[simp] theorem engelHallX_pow (n : â„•) :
    engelHallX ^ n = âں¨0, 0, 2 * (n : â„¤), -6 * (n : â„¤)âں© := by
  induction n with
  | zero => rfl
  | succ n ih =>
      ext <;> simp [engelHallX, pow_succ, ih, EngelCoords.det2] <;> ring

@[simp] theorem engelHallY_pow (n : â„•) :
    engelHallY ^ n = âں¨0, 0, 0, 6 * (n : â„¤)âں© := by
  induction n with
  | zero => rfl
  | succ n ih =>
      ext <;> simp [engelHallY, pow_succ, ih, EngelCoords.det2] <;> ring

@[simp] theorem engelA_zpow (n : â„¤) : engelA ^ n = âں¨n, 0, 0, 0âں© := by
  cases n with
  | ofNat n =>
      simpa [zpow_natCast] using engelA_pow n
  | negSucc n =>
      change engelA ^ Int.negSucc n = âں¨Int.negSucc n, 0, 0, 0âں©
      rw [zpow_negSucc, engelA_pow]
      ext <;> simp [Int.negSucc_eq]

@[simp] theorem engelAconj_zpow (n : â„¤) : engelAconj ^ n = âں¨0, -n, 0, 0âں© := by
  cases n with
  | ofNat n =>
      simpa [zpow_natCast] using engelAconj_pow n
  | negSucc n =>
      change engelAconj ^ Int.negSucc n = âں¨0, -(Int.negSucc n), 0, 0âں©
      rw [zpow_negSucc, engelAconj_pow]
      ext <;> simp [Int.negSucc_eq]

@[simp] theorem engelHallX_zpow (n : â„¤) :
    engelHallX ^ n = âں¨0, 0, 2 * n, -6 * nâں© := by
  cases n with
  | ofNat n =>
      simpa [zpow_natCast] using engelHallX_pow n
  | negSucc n =>
      change engelHallX ^ Int.negSucc n = âں¨0, 0, 2 * Int.negSucc n, -6 * Int.negSucc nâں©
      rw [zpow_negSucc, engelHallX_pow]
      ext <;> simp [Int.negSucc_eq] <;> ring

@[simp] theorem engelHallY_zpow (n : â„¤) :
    engelHallY ^ n = âں¨0, 0, 0, 6 * nâں© := by
  cases n with
  | ofNat n =>
      simpa [zpow_natCast] using engelHallY_pow n
  | negSucc n =>
      change engelHallY ^ Int.negSucc n = âں¨0, 0, 0, 6 * Int.negSucc nâں©
      rw [zpow_negSucc, engelHallY_pow]
      ext <;> simp [Int.negSucc_eq] <;> ring

/-- The order-two symmetry induced by reflection across the `y`-axis in Bodart's path model. -/
def EngelCoords.reflect (g : EngelCoords) : EngelCoords :=
  âں¨-g.v, -g.u, -g.area, -g.bary3âں©

@[simp] theorem EngelCoords.reflect_reflect (g : EngelCoords) :
    g.reflect.reflect = g := by
  ext <;> simp [EngelCoords.reflect]

@[simp] theorem EngelCoords.reflect_mul (g h : EngelCoords) :
    (g * h).reflect = g.reflect * h.reflect := by
  ext <;> simp [EngelCoords.reflect, EngelCoords.det2] <;> ring

/-- Reflection as a multiplicative automorphism of the Engel-coordinate group. -/
def EngelCoords.reflectAut : MulAut EngelCoords where
  toFun := EngelCoords.reflect
  invFun := EngelCoords.reflect
  left_inv := EngelCoords.reflect_reflect
  right_inv := EngelCoords.reflect_reflect
  map_mul' := EngelCoords.reflect_mul

/-- The order-two symmetry adjoining the Engel subgroup. -/
inductive Symmetry where
  | id
  | flip
  deriving DecidableEq, Fintype

instance : One Symmetry where
  one := .id

instance : Mul Symmetry where
  mul
    | .id, x => x
    | .flip, .id => .flip
    | .flip, .flip => .id

instance : Inv Symmetry where
  inv := id

@[simp] theorem Symmetry.inv_id : (Symmetry.id)âپ»آ¹ = Symmetry.id := rfl
@[simp] theorem Symmetry.inv_flip : (Symmetry.flip)âپ»آ¹ = Symmetry.flip := rfl

instance : _root_.Group Symmetry where
  mul_assoc a b c := by
    cases a <;> cases b <;> cases c <;> rfl
  one_mul a := by
    cases a <;> rfl
  mul_one a := by
    cases a <;> rfl
  inv_mul_cancel a := by
    cases a <;> rfl

noncomputable instance : Primcodable Symmetry :=
  Primcodable.ofEquiv (Fin 2) (Fintype.equivFin Symmetry)

/-- The reflection action of the order-two symmetry on Engel coordinates. -/
def symmetryAction : Symmetry â†’* MulAut EngelCoords where
  toFun
    | .id => 1
    | .flip => EngelCoords.reflectAut
  map_one' := rfl
  map_mul' := by
    intro a b
    cases a <;> cases b
    آ· rfl
    آ· rfl
    آ· rfl
    آ· exact DFunLike.ext _ _ fun g => by
        simp [MulAut.mul_apply, EngelCoords.reflectAut, EngelCoords.reflect]

/-- A computable semidirect-product model for Bodart's virtually Engel group. -/
abbrev CoordGroup :=
  EngelCoords â‹ٹ[symmetryAction] Symmetry

/-- The diagonal generator `a` inside the coordinate model. -/
abbrev coordA : CoordGroup :=
  SemidirectProduct.inl engelA

/-- The diagonal generator `b` inside the Engel subgroup. -/
abbrev coordB : CoordGroup :=
  SemidirectProduct.inl âں¨0, 1, 0, 0âں©

/-- The coordinate image of `aلµ—`. -/
abbrev coordAconj : CoordGroup :=
  SemidirectProduct.inl engelAconj

/-- The corrected Hall-style middle commutator. -/
abbrev coordHallX : CoordGroup :=
  SemidirectProduct.inl engelHallX

/-- The central Hall-style commutator. -/
abbrev coordHallY : CoordGroup :=
  SemidirectProduct.inl engelHallY

/-- The order-two symmetry `t` inside the coordinate model. -/
abbrev coordT : CoordGroup :=
  SemidirectProduct.inr Symmetry.flip

/-- The presentation generators interpreted in the computable coordinate model. -/
def coordGenerator : Generator â†’ CoordGroup
  | .a => coordA
  | .t => coordT

@[simp] theorem coordA_zpow (n : â„¤) : coordA ^ n = SemidirectProduct.inl âں¨n, 0, 0, 0âں© := by
  simpa [coordA] using
    (((SemidirectProduct.inl : EngelCoords â†’* CoordGroup).map_zpow engelA n).symm)

@[simp] theorem coordAconj_zpow (n : â„¤) :
    coordAconj ^ n = SemidirectProduct.inl âں¨0, -n, 0, 0âں© := by
  simpa [coordAconj] using
    (((SemidirectProduct.inl : EngelCoords â†’* CoordGroup).map_zpow engelAconj n).symm)

@[simp] theorem coordHallX_zpow (n : â„¤) :
    coordHallX ^ n = SemidirectProduct.inl âں¨0, 0, 2 * n, -6 * nâں© := by
  simpa [coordHallX] using
    (((SemidirectProduct.inl : EngelCoords â†’* CoordGroup).map_zpow engelHallX n).symm)

@[simp] theorem coordHallY_zpow (n : â„¤) :
    coordHallY ^ n = SemidirectProduct.inl âں¨0, 0, 0, 6 * nâں© := by
  simpa [coordHallY] using
    (((SemidirectProduct.inl : EngelCoords â†’* CoordGroup).map_zpow engelHallY n).symm)

@[simp] theorem coordT_sq : coordT * coordT = 1 := by
  native_decide

@[simp] theorem coord_conj_a :
    coordTâپ»آ¹ * coordA * coordT = coordBâپ»آ¹ := by
  native_decide

@[simp] theorem coord_aconj :
    FreeGroup.lift coordGenerator Aconj = coordAconj := by
  native_decide

/-- This records the commutator-convention mismatch: mathlib's `âپ…A, Aconjâپ†` is not the Hall
generator used by the experimentally derived normal forms. -/
@[simp] theorem coord_mathlib_commutator :
    FreeGroup.lift coordGenerator âپ…A, Aconjâپ† = SemidirectProduct.inl âں¨0, 0, 2, 6âں© := by
  native_decide

@[simp] theorem coord_hallX :
    FreeGroup.lift coordGenerator HallX = coordHallX := by
